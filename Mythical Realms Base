function runCommenceShow(p: player):
	set {_holiday} to {Mythical::Holiday}
	set {Mythical::Holiday} to "Party"
	set time in world "Mythical_Realms" to night
	loop all players:
		send title "" with subtitle "The Fireworks Show is About to Start!" to loop-player
		send " {@info} &fThe Fireworks Show is About to Start!" to loop-player
		send " {@info} &fHead to the &6Galliant Gazebo&f to Watch!" to loop-player
	wait 20 seconds
	loop all players:
		play sound "block.note_block.pling" at loop-player
		wait 1 second
		play sound "block.note_block.pling" at loop-player
		wait 1 second
		play sound "block.note_block.pling" with pitch 2 at loop-player
		wait 1 second
	execute console command "/discordbroadcast chat {@info} &fThe Fireworks Show is Starting!"
	broadcast " {@info} &fThe Fireworks Show is Starting!"
	set {_center} to location(-382.5, 107, 1275.5, world("Mythical_Realms"))
	set {_left} to {_center}
	remove {@spread} from z-coord of {_left}
	set {_right} to {_center}
	add {@spread} to z-coord of {_right}
	set {_farLeft} to {_left}
	remove {@spread} from z-coord of {_farLeft}
	set {_farRight} to {_right}
	add {@spread} to z-coord of {_farRight}
	loop 4 times:
		launch flickering star coloured yellow fading to white at {_center} with duration 1
		play sound "entity.experience_orb.pickup" with pitch 0.5 at {_center}
		wait 2 seconds
		loop 3 times:
			if {commencefw::running} is false:
				stop
			launch flickering ball coloured gold fading to white at {_center} with duration 1
			wait 5 ticks
			launch flickering ball coloured gold fading to yellow at {_left} with duration 1
			launch flickering ball coloured gold fading to yellow at {_right} with duration 1
			play sound "entity.firework_rocket.launch" at {_center}
			wait 15 ticks
		wait 1 second
		loop 5 times:
			if {commencefw::running} is false:
				stop
			launch flickering ball large coloured red fading to purple at {_farLeft} with duration 2
			wait 3 ticks
			launch flickering ball coloured purple fading to blue at {_left} with duration 2
			wait 3 ticks
			launch flickering star coloured blue fading to aqua at {_center} with duration 2
			wait 3 ticks
			launch flickering ball coloured aqua fading to green at {_right} with duration 2
			wait 3 ticks
			launch flickering ball large coloured green fading to lime at {_farRight} with duration 2
			wait 10 ticks
			launch flickering ball large coloured lime fading to yellow at {_farRight} with duration 2
			wait 3 ticks
			launch flickering ball coloured yellow fading to orange at {_right} with duration 2
			wait 3 ticks
			launch flickering creeper coloured orange fading to red at {_center} with duration 2
			wait 3 ticks
			launch flickering ball coloured red fading to pink at {_left} with duration 2
			wait 3 ticks
			launch flickering ball large coloured pink fading to purple at {_farLeft} with duration 2
			wait 10 ticks
		loop 4 times:
			if {commencefw::running} is false:
				stop
			launch flickering burst coloured white fading to gray at {_left} with duration 0.5
			launch flickering burst coloured white fading to gray at {_right} with duration 0.5
			launch flickering ball large coloured blue fading to white at {_center} with duration 3
			wait 10 ticks
			launch flickering ball large coloured red fading to white at {_farLeft} with duration 3
			launch flickering ball large coloured red fading to white at {_farRight} with duration 3
			wait 1 second
		play sound "entity.creeper.primed" at {_p}
		wait 1 second
		launch flickering creeper coloured lime fading to green at {_center} with duration 2
		wait 10 ticks
		launch flickering creeper coloured green fading to black at {_left} with duration 2
		launch flickering creeper coloured green fading to black at {_right} with duration 2
		wait 10 ticks
		launch flickering creeper coloured lime fading to white at {_farLeft} with duration 3
		launch flickering creeper coloured lime fading to white at {_farRight} with duration 3
		play sound "entity.firework_rocket.large_blast" with volume {@volume} at {_center}
		play sound "entity.generic.explode" with volume {@volume} and pitch 0.8 at {_center}
	wait 2 seconds
	set {_finale_colors::*} to red, orange, yellow, green, blue, purple, white
	loop 10 times:
		launch flickering ball coloured random color out of {_finale_colors::*} at {_center} with duration 1
		wait 2 ticks
	loop 8 times:
		if {commencefw::running} is false:
			stop
		launch flickering ball large coloured random color out of {_finale_colors::*} fading to white at {_farLeft} with duration 2
		launch flickering ball large coloured random color out of {_finale_colors::*} fading to white at {_farRight} with duration 2
		wait 2 ticks
		launch flickering ball coloured random color out of {_finale_colors::*} fading to white at {_left} with duration 2
		launch flickering ball coloured random color out of {_finale_colors::*} fading to white at {_right} with duration 2
		wait 2 ticks
		launch flickering star coloured random color out of {_finale_colors::*} fading to gold at {_center} with duration 3
		play sound "entity.firework_rocket.blast" at {_center}
		wait 3 ticks
	wait 10 ticks
	loop 5 times:
		play sound "entity.firework_rocket.large_blast" with volume {@volume} at {_center}
		play sound "entity.generic.explode" with volume {@volume} and pitch 0.8 at {_center}
		launch flickering ball large coloured gold fading to white at {_farLeft} with duration 2
		launch flickering ball large coloured gold fading to white at {_left} with duration 2.5
		launch flickering ball large coloured white fading to red at {_center} with duration 3
		launch flickering ball large coloured gold fading to white at {_right} with duration 2.5
		launch flickering ball large coloured gold fading to white at {_farRight} with duration 2
		launch flickering burst coloured red at {_left} with duration 0
		launch flickering burst coloured red at {_right} with duration 0
		wait 5 ticks
	wait 2 seconds
	launch flickering star coloured white fading to black at {_center} with duration 2
	play sound "entity.firework_rocket.twinkle" at {_center}
	wait 3 seconds
	set {commencefw::running} to false
	set {Mythical::Holiday} to {_holiday}
	loop all players:
		send title "" with subtitle "That's All The Fireworks For Now!" to loop-player
		send " {@info} &fThat's All The Fireworks For Now!" to loop-player
		send " {@info} &fCheck Back Soon to See Them Again!" to loop-player
command /commenceshow [<text>]:
	permission: op
	trigger:
		if arg-1 is "stop":
			set {commencefw::running} to false
			send "{@prefix} &cStopping the show..."
			stop
		if {commencefw::running} is true:
			send "{@prefix} &cA show is already running! Use &7/commenceshow stop"
			stop
		set {commencefw::running} to true
		send "{@prefix} &eInitializing the show..."
		runCommenceShow(player)
