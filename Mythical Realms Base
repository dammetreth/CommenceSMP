	{Mythical::Toggle} is true
	world is {@worlds}
	event-entity is a zombie or a skeleton or a spider
	cancel event

on shoot:
	{Mythical::Toggle} is true
	world is {@worlds}
	event-projectile is snowball
	region at shooter contains "eventarea":
		cancel event

on damage:
	{Mythical::Toggle} is true
	attacker's world is {@worlds}
	victim's world is {@worlds}
	victim is not a monster:
		region at attacker contains "centralhub"
		cancel event
		stop
	{Mythical::%victim%::Tutorial} or {Mythical::%attacker%::Tutorial} is set:
		cancel event
		stop
	increase damage by {Mythical::%{_p}%::AttackDamage} if {Mythical::%{_p}%::AttackDamage} is more than 0
	increase damage by {Mythical::%{_p}%::Defense} * -1 if {Mythical::%{_p}%::Defense} is more than 0
	attacker is a player:
		add damage to {Mythical::%attacker%::Damage::Given}
		attacker's gamemode is survival
		{Mythical::Items::Wands::*} contains attacker's tool:
			castSpell(attacker)
		attacker's tool is tagged with minecraft tag "swords":
			assignSkill(attacker, "Swordsman")
		attacker's tool is tagged with minecraft tag "axes":
			assignSkill(attacker, "Swordsman")
		attacker's tool is a bow or a crossbow:
			assignSkill(attacker, "Archer")
		set {Mythical::%attacker%::Battle::Timer} to 6 if {Mythical::%attacker%::Battle::Timer} is not set
		add 2 to {Mythical::%attacker%::Battle::Timer} if {Mythical::%attacker%::Battle::Timer} < 9
	victim is a player:
		add damage to {Mythical::%victim%::Damage::Taken}
		damage cause is fall:
			assignSkill(victim, "Acrobat")

	#CUSTOM CONDITIONS
	event-projectile is snowball:
		attacker is a player
		uncolored {Mythical::%attacker%::Magic::Spell} contains "Arctic Spear"
		{Mythical::%attacker%::Magic::Wait} is true
		increase damage by 0.5 + {Mythical::%attacker%::MagicPower}
	else:
		attacker is a player
		uncolored {Mythical::%attacker%::Magic::Spell} contains "Featherfall Blade":
			{Mythical::%attacker%::Magic::Wait} is true
