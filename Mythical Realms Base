command /formmanual:
	aliases: mrmanual
	usage: <#CB625F>/mrmanual
	description: &7Player's Mythical Realms Forms Manual
#	cooldown: 1 second
#	cooldown message: {@cooldownmessage}
#	cooldown storage: {Commence::%player%::Wait}
	trigger:
		{Mythical::Toggle} is true
		set {_manual} to a written book
		uncolored {Mythical::%player%::Form::Type} contains "Fire":
			set book title of {_manual} to "<#C46D23>Fire Form"
			set {_a} to text component of "The Fire Form channels the volatile power of molten flame and volcanic energy, making it perfect for players who thrive on chaos, damage, and fast-paced combat. Fire-aligned characters excel at dealing area-of-effect damage, inflicting burn effects on enemies, and"
			set {_b} to text component of "gaining momentum when low on health. They’re naturally resistant to heat and lava but are more vulnerable to water and frost magic. Fire Forms struggle with stealth due to a faint fiery aura and cannot regenerate health while in combat. Their magic may also misfire if cast too recklessly,"
			set {_c} to text component of "reflecting the unstable nature of fire. Ideal for bold players who want to overwhelm foes quickly and light up the battlefield — sometimes literally. &cBy Leaving the Starting Area, You'll Become an <#C46D23>Fire Form!"
		else if uncolored {Mythical::%player%::Form::Type} contains "Water":
			set book title of {_manual} to "<#4AA7D3>Water Form"
			set {_a} to text component of "The Water Form draws its power from flowing rivers and crashing waves, offering adaptability, restoration, and smooth motion. Water-aligned players enjoy enhanced healing abilities, faster movement in water, and immunity to drowning, making them excellent support"
			set {_b} to text component of "casters or solo survivors. Their connection to fluidity grants temporary movement boosts and faster recovery outside of combat. However, they’re physically more fragile, with reduced melee speed and heightened vulnerability to lightning magic. Their"
			set {_c} to text component of "buffs tend to fade quickly in dry or arid areas, keeping them tied to terrain strategy. The Water Form is best for players who prefer healing, supportive versatility, and strategic repositioning. &cBy Leaving the Starting Area, You'll Become an <#4AA7D3>Water Form!"
		else if uncolored {Mythical::%player%::Form::Type} contains "Earth":
			set book title of {_manual} to "<#776249>Earth Form"
			set {_a} to text component of "The Earth Form embodies resilience, strength, and control, forged from tectonic pressure and ancient stone. Earth-aligned players benefit from bonus armor when holding still, reduced knockback, a passive thorns effect, and faster resource gathering when mining. This makes them"
			set {_b} to text component of "excellent for defensive strategies, area control, and solo play in harsh environments. However, Earth Forms move slower, cast slower, and are vulnerable to magic that bypasses armor, such as poison or pure Arcane. They also lack vertical mobility and struggle"
			set {_c} to text component of "in watery terrain. Earth is best suited for patient, tactical players who want to dominate through endurance and control rather than speed. &cBy Leaving the Starting Area, You'll Become an <#776249>Earth Form!"
		else if uncolored {Mythical::%player%::Form::Type} contains "Air":
			set book title of {_manual} to "<#A5B2B7>Air Form"
			set {_a} to text component of "The Air Form is all about freedom, speed, and evasive precision. Born from wind currents and high altitudes, this form grants natural double jumps, fall damage resistance, and faster casting speeds, especially for ranged or light spells. Air players are hard to pin down, often"
			set {_b} to text component of "gaining speed boosts when untouched for short periods and occasionally dodging incoming projectiles outright. However, their agility comes at a cost: reduced max health, less knockback resistance, and difficulty maintaining accuracy in enclosed areas. Heavy armor limits their mobility," 
			set {_c} to text component of "forcing a light-footed, fast-thinking playstyle. Perfect for skirmishers, explorers, and casters who favor finesse over brute force. &cBy Leaving the Starting Area, You'll Become an <#A5B2B7>Air Form!"
		else:
			set book title of {_manual} to "&fNo Form Selected"
			set {_a} to text component of "&fHey, what do you think you're doing, clever little one? You haven't selected a Form Race yet! Type <#D0944D>/mrforms&f and choose one of the options! If you don't like it, type the command again! If you do like it, proceed forward! Good luck now!"
		set page 1 of book {_manual} to {_a}
		set page 2 of book {_manual} to {_b}
		set page 3 of book {_manual} to {_c}
		set book author of {_manual} to "&k<#D0944D>Mythical Realms"
		open book {_manual} to player
		clear {_a}
		clear {_b}
		clear {_c}

