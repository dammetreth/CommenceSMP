command /event [<text>]:
	aliases: /events
	usage: <#CB625F>/events
	description: &7Mythical Realms Events
#	cooldown: 1 second
#	cooldown message: {@cooldownmessage}
#	cooldown storage: {Commence::%player%::Wait}
	trigger:
		arg-1 is set:
			stop
		else:
			set metadata tag "mrevents" of player to chest inventory with 3 rows named "{@mythicalrealms} Events"
			guiBar(player, "mrevents")
			set slot 13 of metadata tag "mrevents" of player to stone with item flags hide enchants and hide attributes named "&aHalloween Event" with lore "{@mythicalrealms} Grand Opening!" and "&f The Public Release of Alpha 1.0!" and "&7 " and "&cComing October 31, 2025!"
			open (metadata tag "mrevents" of player) to player

command /map [<text>]:
	aliases: /map
	usage: <#CB625F>/map
	description: &7Mythical Realms Minigames
#	cooldown: 1 second
#	cooldown message: {@cooldownmessage}
#	cooldown storage: {Commence::%player%::Wait}
	trigger:
		{Mythical::Toggle} is true
		{Mythical::%player%::Form::Type} is set
		player's world is {@worlds}
		set metadata tag "mrmap" of player to chest inventory with 6 rows named "{@mythicalrealms} Map"
		loop 56 times:
			set slot (loop-value - 1) of metadata tag "mrmap" of player to gray stained glass pane named "&7"
		arg-1 is not set:
			guiBar(player, "mrmap")
			set slot 31 of metadata tag "mrmap" of player to lime stained glass pane with item flags hide enchants and hide attributes named "&aOak Commons (Main Hub)" with lore "&f You Discovered This Area!" and ""#"&f You Can Warp Here!" and "&f " and "&aClick to Warp to Central Castle"
			open (metadata tag "mrmap" of player) to player

command /warp <text>:
	usage: <#CB625F>/magicschool
	description: &7Mythical Realms Warp
#	cooldown: 2 seconds
#	cooldown message: {@cooldownmessage}
#	cooldown storage: {Commence::%player%::Wait}
	trigger:
		{Mythical::Toggle} is true
		{Mythical::%player%::Form::Type} is set
		set {_w} to arg-1
		replace all " " in {_w} with ""
		{_w} contains "CentralHub" or "OakCommons" or "MainHub":
			set {_w} to "CentralHub"
		else if {_w} contains "MagicSchool" or "SchoolofMagic" or "PrismPromenade":
			set {_w} to "MagicSchool"
		else if {_w} contains "QuestHall" or "AdventureHall" or "OakshadeHall":
			set {_w} to "QuestHall"
		{Mythical::%player%::Area::%region at {Mythical::Area::%{_w}%}%} is set:
			teleport player to {Mythical::Area::%{_w}%}
			set {_r} to "%region at player%"
			replace all " in world %player's world%" in {_r} with ""
			send "{@story}"
			send "&7  Now Teleporting to <#3988A3>%{Mythical::Region::%{_r}%::Title}%"
		else:
			send "{@story}"
			send "&c  You Haven't Discovered That Area Yet!"
		clear {_w}
		clear {_r}

