function assignLevel(p: player):
	{Mythical::Toggle} is true
	{_p}'s world is {@worlds}
	add 1 to {Mythical::%{_p}%::Level::Progress}
	({Mythical::%{_p}%::Level::Title} * ({Mythical::Level::Upgrade} + round({Mythical::%{_p}%::Level::Title} * 6.3))) < ({Mythical::%{_p}%::Level::Progress} - 1):
		add 1 to {Mythical::%{_p}%::Level::Title}
		play sound "entity.player.levelup" at volume 100 at pitch 10 to {_p}
		play sound "item.totem.use" at volume 100 at pitch 100 to {_p}
		send title "" with subtitle "{@levelup}&fYour Vitality Level is Now %{Mythical::%{_p}%::Level::Title}%" to {_p}
		send "{@levelup}<#00C889>Your Vitality Level is Now %{Mythical::%{_p}%::Level::Title}%!" to {_p}
		add random integer between 1 and {Mythical::%{_p}%::Level::Title} to {Mythical::%{_p}%::Magic::Mana}
		add random integer between 1 and {Mythical::%{_p}%::Level::Title} to {Mythical::%{_p}%::Money}
		{Mythical::Upgrades::Health::%{Mythical::%{_p}%::Level::Title}%} is set:
			wait 10 seconds
			set {Mythical::%{_p}%::MaxHealth} to 10 if {Mythical::%{_p}%::MaxHealth} is not set
			set {Mythical::%{_p}%::AttackDamage} to 0 if {Mythical::%{_p}%::AttackDamage} is not set
			set {Mythical::%{_p}%::Defense} to 0 if {Mythical::%{_p}%::Defense} is not set
			set {Mythical::%{_p}%::MagicPower} to 0 if {Mythical::%{_p}%::MagicPower} is not set
			send title "{@healthupgrade}" with subtitle "" to {_p}
			send "{@healthupgrade}&fYou Now Have %{Mythical::%{_p}%::MaxHealth} + {Mythical::Upgrades::Health::%{Mythical::%{_p}%::Level::Title}%}% Hearts!" to {_p}
			set {Mythical::%{_p}%::MaxHealth} to {Mythical::%{_p}%::MaxHealth} + {Mythical::Upgrades::Health::%{Mythical::%{_p}%::Level::Title}%}
			send "{@attackupgrade}&fYou Now Deal %{Mythical::%{_p}%::AttackDamage} + {Mythical::Upgrades::Attack::%{Mythical::%{_p}%::Level::Title}%}% Damage Per Hit!" to {_p}
			set {Mythical::%{_p}%::AttackDamage} to {Mythical::%{_p}%::AttackDamage} + {Mythical::Upgrades::Attack::%{Mythical::%{_p}%::Level::Title}%}
			send "{@defenseupgrade}&fYou Now Prevent %{Mythical::%{_p}%::Defense} + {Mythical::Upgrades::Defense::%{Mythical::%{_p}%::Level::Title}%}% Damage Per Hit!" to {_p}
			set {Mythical::%{_p}%::Defense} to {Mythical::%{_p}%::Defense} + {Mythical::Upgrades::Defense::%{Mythical::%{_p}%::Level::Title}%}
			send "{@magicupgrade}&fYou Now Deal %{Mythical::%{_p}%::MagicPower} + {Mythical::Upgrades::Magic::%{Mythical::%{_p}%::Level::Title}%}% More Damage Per Spell!" to {_p}
			set {Mythical::%{_p}%::MagicPower} to {Mythical::%{_p}%::MagicPower} + {Mythical::Upgrades::Magic::%{Mythical::%{_p}%::Level::Title}%}
		{Mythical::Spells::%uncolored {Mythical::%{_p}%::Form::Type}%::%{Mythical::%{_p}%::Level::Title}%} is set:
			wait 10 seconds
			{Mythical::Spells::%uncolored {Mythical::%{_p}%::Form::Type}%::%uncolored {Mythical::Spells::%uncolored {Mythical::%{_p}%::Form::Type}%::%{Mythical::%{_p}%::Level::Title}%}%Title} is not set:
				send " {@info} ISSUE! ERROR! PROBLEM! GET IT TOGETHER!" to {_p}
			{Mythical::%{_p}%::Magic::Spellbook::*} does not contain {Mythical::Spells::%uncolored {Mythical::%{_p}%::Form::Type}%::%uncolored {Mythical::Spells::%uncolored {Mythical::%{_p}%::Form::Type}%::%{Mythical::%{_p}%::Level::Title}%}%Title}:
				add {Mythical::Spells::%uncolored {Mythical::%{_p}%::Form::Type}%::%uncolored {Mythical::Spells::%uncolored {Mythical::%{_p}%::Form::Type}%::%{Mythical::%{_p}%::Level::Title}%}%Title} to {Mythical::%{_p}%::Magic::Spellbook::*}
				send title "{@spelllearn}%{Mythical::Spells::%uncolored {Mythical::%{_p}%::Form::Type}%::%uncolored {Mythical::Spells::%uncolored {Mythical::%{_p}%::Form::Type}%::%{Mythical::%{_p}%::Level::Title}%}%Title}%" with subtitle "Type /magic to Check Out Your New Spell!" to {_p}
				send "{@spelllearn}%{Mythical::Spells::%uncolored {Mythical::%{_p}%::Form::Type}%::%uncolored {Mythical::Spells::%uncolored {Mythical::%{_p}%::Form::Type}%::%{Mythical::%{_p}%::Level::Title}%}%Title}%" to {_p}
				send "&f  Info: %{Mythical::Spells::%uncolored {Mythical::%{_p}%::Form::Type}%::%uncolored {Mythical::Spells::%uncolored {Mythical::%{_p}%::Form::Type}%::%{Mythical::%{_p}%::Level::Title}%}%Description}%" to {_p}
				send "&f  Type /magic to Check Out Your New Spell!" to {_p}

function assignSkill(p: player, s: text):
	{Mythical::Toggle} is true
	{_p}'s world is {@worlds}
	assignLevel({_p})
	{Mythical::%{_p}%::Skill::%{_s}%} is not true:
		send "{@skilllearn}%{_s}%&7 stats are in <#00C889>/skills&7!" to {_p}
		send title "" with subtitle "&7{@skilllearn}&f%{_s}%&7" to {_p}
		set {Mythical::%{_p}%::Skill::%{_s}%} to true
	add 1 to {Mythical::%{_p}%::Skill::%{_s}%::Progress}
	({Mythical::%{_p}%::Skill::%{_s}%::Level} * ({Mythical::Skill::%{_s}%::Level::Upgrade} + {Mythical::%{_p}%::Skill::%{_s}%::Level})) < ({Mythical::%{_p}%::Skill::%{_s}%::Progress} + 1):
		add 1 to {Mythical::%{_p}%::Skill::%{_s}%::Level}
		send "{@skillupgrade}%{_s}%&7 is now level %{Mythical::%{_p}%::Skill::%{_s}%::Level}%" to {_p}
		send title "" with subtitle "{@skillupgrade}&f%{_s}%&f is now level %{Mythical::%{_p}%::Skill::%{_s}%::Level}%" to {_p}
		add random integer between 1 and {Mythical::%{_p}%::Skill::%{_s}%::Level} to {Mythical::%{_p}%::Magic::Mana}
		add random integer between 1 and {Mythical::%{_p}%::Skill::%{_s}%::Level} to {Mythical::%{_p}%::Money}
	set {Mythical::%{_p}%::Skill::Active} to {_s}
	sbMythical({_p})

