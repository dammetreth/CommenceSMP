					set block below block at {Mythical::%player%::Minigame::Slot} to farmland
					set block at {Mythical::%player%::Minigame::Slot} to wheat[age=0]
					set {Mythical::Minigame::Farmer::Location::%loop-value%} to player
					make player face loop-value's location
					stop loop
			wait 20 ticks
			set {Mythical::%player%::Minigame} to true
			minigameFarmer(player)

	if event-inventory is (metadata tag "mrminigamefisher" of player):
		cancel event
		event-slot is 13:
			loop all blocks in radius 10 of player:
				loop-block is water
				set {Mythical::%player%::Quest::Main::Condition} to false if {Mythical::%player%::Quest::Main::Condition} is "Fisher"
				{Mythical::%player%::Minigame} is not true
				close inventory of player
				set {Mythical::%player%::Fisher} to true
				set {Mythical::%player%::Minigame::Score} to 0
				set {Mythical::%player%::Minigame::Timer} to 0
				set {Mythical::%player%::Minigame} to true
				minigameFisher(player)
				stop
			close inventory of player
			send " {@info} You're Not Close Enough to Water" to player

	if event-inventory is (metadata tag "mrminigameminer" of player):
		cancel event
		event-slot is 13:
			set {Mythical::%player%::Quest::Main::Condition} to false if {Mythical::%player%::Quest::Main::Condition} is "Miner"
			{Mythical::%player%::Minigame} is not true
			loop 14 times:
				clear slot loop-value - 1 of metadata tag "mrminigameminer" of player
			close inventory of player
			set {Mythical::%player%::Miner} to true
			set {Mythical::%player%::Minigame::Score} to 0
			set {Mythical::%player%::Minigame::Timer} to 0
			loop {Mythical::Minigame::Miner::Locations::*}:
				{Mythical::Minigame::Miner::Location::%loop-value%} is not set:
					teleport player 1 meter east or 1 meter west or 1 meter north or 1 meter south of block at loop-value
					set {Mythical::%player%::Minigame::Slot} to block at loop-value
					set block at {Mythical::%player%::Minigame::Slot} to stone
					set {Mythical::Minigame::Miner::Location::%loop-value%} to player
					make player face loop-value's location
					stop loop
			wait 20 ticks
			set {Mythical::%player%::Minigame} to true
			minigameMiner(player)

	if event-inventory is (metadata tag "mrminigamedungeon" of player):
		cancel event
		event-slot is 13:
			close inventory of player
			{Mythical::%player%::Dungeon::Active} is not set:
				loop 99 times:
					distance between block at {Mythical::Dungeon::%loop-value%::LocWait} and block under player is less than 6
					set {Mythical::%player%::Dungeon::Active} to loop-value
					stop loop
				{Mythical::%player%::Dungeon::Active} is not set:
					send " {@info} You Aren't Close Enough to a Dungeon"
					send " {@info} Move Closer to a Dungeon Enterance and Try Again!"
					stop
				else if {Mythical::Dungeon::%{Mythical::%player%::Dungeon::Active}%::Status} is not "Recruiting":
					send " {@info} %{Mythical::Dungeon::%{Mythical::%player%::Dungeon::Active}%::Title}% is Currently Active"
					send " {@info} Please Try to Join the Dungeon Later!"
					stop
				dungeonMaster(player)
			else:
				send " {@info} You're Already Waiting to Enter %{Mythical::Dungeon::%{Mythical::%player%::Dungeon::Active}%::Title}%"
				stop
				

