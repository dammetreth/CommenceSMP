on respawn:
	{Mythical::Toggle} is true
	player's world is {@worlds}
	{Mythical::%player%::Deaths::Taken} is less than 2:
		assignKit(player, {Mythical::%player%::Form::Type})
	{Mythical::%player%::Dungeon::Active} is set:
		teleport player to {Mythical::Dungeon::%{Mythical::%player%::Dungeon::Active}%::LocStart}

on death:
	{Mythical::Toggle} is true
	victim is a player:
		attacker is set:
			set death message to "&6 %victim's display name ? victim% &8died to %attacker's tool's name ? damage cause%&8 from %attacker's display name ? attacker%"
		else:
			set death message to "&6 %victim's display name ? victim% &8died from %attacker's tool's name ? damage cause%"
	victim's world is {@worlds}
	#attacker's world is {@worlds} if attacker is set
	kill {Mythical::%victim%::Health}
	clear {Mythical::%victim%::Health}
	clear {Mythical::%victim%::Name}
	{Mythical::%victim%::Tutorial} or {Mythical::%attacker%::Tutorial} is set:
		cancel event
		stop
	add 1 to {Mythical::%victim%::Deaths::Taken} if victim is a player
	attacker is a player:
		add 1 to {Mythical::%attacker%::Deaths::Given}
		attacker's gamemode is survival
		attacker's tool is tagged with minecraft tag "swords":
			loop random integer between 2 and 5 times:
				assignSkill(attacker, "Swordsman")
				wait 1 tick
		attacker's tool is tagged with minecraft tag "axes":
			loop random integer between 2 and 5 times:
				assignSkill(attacker, "Swordsman")
				wait 1 tick
		attacker's tool is a bow or a crossbow:
			loop random integer between 2 and 5 times:
				assignSkill(attacker, "Archer")
				wait 1 tick
		uncolored name of attacker's tool contains "Magic":
			loop random integer between 2 and 5 times:
				assignSkill(attacker, "Swordsman")
				wait 1 tick
		uncolored {Mythical::%attacker%::Quest::Main::Title} contains "%victim%":
