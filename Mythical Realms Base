			set {Mythical::%victim%::Health}'s display name to "&8%{_tn}%<#CB625F> | &4%length of {_ta}% %{_ta}%<#CB625F> | <#CB625F>"
			set {Mythical::%victim%::Health}'s display name to "&8%{_tn}%<#CB625F> | &4%length of {_ta}% ♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥♥+<#CB625F> | <#CB625F>" if {_th} is more than 49
