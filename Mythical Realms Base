function assignDialogueVoice(p: player, v: text, l: text):
	{Mythical::%{_p}%::Sound} is true
	{_l} contains "a" or "e" or "i" or "o" or "u" or "y" or "h" or "r"
	#PERSONALITIES: Quirky, Serious, Funny, Calm, Angry, Intense, Mean, Energetic, Talkative, Comforting, Absent, Quiet
	{_v} is "Quirky":
		set {_rp} to random number between 1.7 and 2.3
		set {_rv} to 0.8
	{_v} is "Serious":
		set {_rp} to random number between 0.6 and 0.7
		set {_rv} to 0.8
	{_v} is "Funny":
		set {_rp} to random number between 1.2 and 1.7
		set {_rv} to 1
	{_v} is "Calm":
		set {_rp} to random number between 1 and 1.2
		set {_rv} to 0.5
	{_v} is "Angry":
		set {_rp} to random number between 0.5 and 0.9
		set {_rv} to 1.2
	{_v} is "Intense":
		set {_rp} to random number between 0.8 and 1.2
		set {_rv} to 1.3
	{_v} is "Mean":
		set {_rp} to random number between 0.6 and 0.8
		set {_rv} to 1
	{_v} is "Energetic":
		set {_rp} to random number between 1.5 and 2
		set {_rv} to 1
	{_v} is "Talkative":
		set {_rp} to random number between 1.2 and 1.7
		set {_rv} to 0.8
	{_v} is "Comforting":
		set {_rp} to 1
		set {_rv} to 0.7
	{_v} is "Absent":
		set {_rp} to random number between 1.8 and 2.3
		set {_rv} to 0.8
	{_v} is "Quiet":
		set {_rp} to random number between 0.8 and 1.2
		set {_rv} to 0.5
	{_v} is not set:
		set {_rp} to 1
		set {_rv} to 0.8
	{_l} contains "a" or "e":
		play sound "entity.villager.trade" at volume {_rv} at pitch {_rp} to {_p}
	{_l} contains "h" or "i":
		play sound "entity.villager.celebrate" at volume {_rv} at pitch {_rp} to {_p}
	{_l} contains "o" or "u":
		play sound "entity.villager.no" at volume {_rv} at pitch {_rp} to {_p}
	{_l} contains "y" or "r":
		play sound "entity.villager.trade" at volume {_rv} at pitch {_rp} to {_p}

function assignDialogue(p: player, n: entity):
	send "Passed Test assignDialogue" to {_p} if {Mythical::Debugger} is true
#	wait 10 ticks
	{Mythical::%{_p}%::Words} is not set
	{Mythical::%{_p}%::Dialogues::*} is not set
	set {Mythical::%{_p}%::NPCTemp} to first element of ({_n}'s name split at " ") ? "A Stranger"
	set {Mythical::%{_p}%::NPCTemp} to {Mythical::NPC::%{_n}%::FullName} ? first element of ({_n}'s name split at " ") ? "A Stranger"# if {Mythical::%{_p}%::FullNames} is true
	set {Mythical::%{_p}%::UUIDNPCTemp} to uuid of {_n}
