function assignKit(p: player, f: text):
	{Mythical::%{_p}%::Kit::Cooldown} is set:
		send " {@info} Please Wait %{Mythical::%{_p}%::Kit::Cooldown}% Seconds to Get Another Kit" to {_p}
		stop
	set {Mythical::%{_p}%::Kit::Cooldown} to 2400
	set {_h} to {Mythical::Items::Helmets::StarterHelmet}
	set {_c} to {Mythical::Items::Chestplates::StarterChestplate}
	set {_l} to {Mythical::Items::Leggings::StarterLeggings}
	set {_b} to {Mythical::Items::Boots::StarterBoots}
	uncolored {Mythical::%{_p}%::Form::Type} contains "Water":
		dye {_h} white
		dye {_c} light blue
		dye {_l} blue
		dye {_b} blue
	else if uncolored {Mythical::%{_p}%::Form::Type} contains "Air":
		dye {_h} white
		dye {_c} light gray
		dye {_l} dark gray
		dye {_b} dark gray
	else if uncolored {Mythical::%{_p}%::Form::Type} contains "Fire":
		dye {_h} yellow
		dye {_c} orange
		dye {_l} red
		dye {_b} red
	else if uncolored {Mythical::%{_p}%::Form::Type} contains "Earth":
		dye {_h} green
		dye {_c} brown
		dye {_l} brown
		dye {_b} brown	
	give {_p} {Mythical::Items::Pickaxes::StarterPickaxe}
	give {_p} {Mythical::Items::Swords::StarterSword}
	give {_p} {Mythical::Items::Axes::StarterAxe}
	equip {_p} with {_h} named "<#D0944D>Starter Helmet" with lore "%{Mythical::%{_p}%::Form::Type}% Form Specialized"
	equip {_p} with {_c} named "<#D0944D>Starter Chestplate" with lore "%{Mythical::%{_p}%::Form::Type}% Form Specialized"
	equip {_p} with {_l} named "<#D0944D>Starter Leggings" with lore "%{Mythical::%{_p}%::Form::Type}% Form Specialized"
	equip {_p} with {_b} named "<#D0944D>Starter Boots" with lore "%{Mythical::%{_p}%::Form::Type}% Form Specialized"
	give {_p} 16 of bread
	give {_p} 64 of torch

command /kit:
	aliases: /kits, /kit, /mrkits, /mrkit
	usage: <#CB625F>/mrkit
	description: &7Mythical Realms Kits
	trigger:
		assignKit(player, {Mythical::%player%::Form::Type})

command /mrcutsceneadmin <text> [<integer>] [. <integer>]:
	usage: <#CB625F>/mrcutsceneadmin [ TEXT ]
	description: &7Mythical Realms Admin
#	cooldown: 2 seconds
#	cooldown message: {@cooldownmessage}
#	permission: commencer.inspector
#	permission message: {@permissionmessage}
	trigger:
		arg-1 is "clearcutscene":
			clear {Mythical::Cutscene::*}
			send "Cleared Cutscene Data"
		arg-1 is "playcutscene":
			arg-2 is set
			{Mythical::Cutscene::Camera::%arg-2%::*} is set:
				cutscenePlayer(player, arg-2)
				stop
			else:
				send " {@info} %arg-2% is Not a Valid Cutscene"
				stop
		arg-1 is "recordcutscene":
			arg-2 is set
			arg-3 is set
			{Mythical::Cutscene::Camera::%arg-2%::*} is set:
				send " {@info} %arg-2% is Already Recorded, Modify or Remove it"
				stop
			else:
				cutsceneRecorder(player, arg-2, arg-3)
				stop
		arg-1 is "removecutscene" or "deletecutscene":
			arg-2 is set
			{Mythical::Cutscene::Camera::%arg-2%::*} is set:
				send " {@info} %arg-2% Has Been Removed Successfully"
				delete {Mythical::Cutscene::Camera::%arg-2%::*}
				stop
			else:
				send " {@info} %arg-2% is Not a Valid Cutscene"
				stop

command /secretsanta:
	usage: <#CB625F>/secretsanta
	description: &7Mythical Realms Admin
#	cooldown: 2 seconds
#	cooldown message: {@cooldownmessage}
	trigger:
		{Mythical::%player%::SecretSanta} is set:
			send " {@info} &aYou've Already Been Given a Secret Santa Gift Receipient:" to player
			send " {@info} &cPlayer: &c%{Mythical::%player%::SecretSanta}%" to player
			send " {@info} &aMake a Custom Model in BB for them! Submit them to Cdestre when done!" to player
			send " {@info} &cName the model 'secret_santa.bbmodel', please!" to player
			send " {@info} &aAnd please, do NOT tell ANYONE who you have! It's SECRET Santa for a reason!" to player
			send " {@info} &cHave fun!" to player
			stop
		stop if {Mythical::Santas::*} contains "NONE"
		set {Mythical::%player%::SecretSanta} to random element of {Mythical::Santas::*}
		clear {Mythical::%player%::SecretSanta} if uncolored player's name contains {Mythical::%player%::SecretSanta}
		{Mythical::%player%::SecretSanta} is not set:
			send " {@info} You drew yourself. Try again! &a/secretsanta"
			stop
		remove {Mythical::%player%::SecretSanta} from {Mythical::Santas::*}
		send " {@info} &aYou've Been Given a Secret Santa Gift Receipient:" to player
		send " {@info} &cPlayer: &c%{Mythical::%player%::SecretSanta}%" to player
		send " {@info} &aMake a Custom Model in BB for them! Submit them to Cdestre when done!" to player
		send " {@info} &cName the model 'secret_santa.bbmodel', please!" to player
		send " {@info} &aAnd please, do NOT tell ANYONE who you have! It's SECRET Santa for a reason!" to player
		send " {@info} &cHave fun!" to player
		execute console command "/discordbroadcast chat {@info} That's all for Secret Santa! Everyone has their person. Good luck!" if {Mythical::Santas::*} contains "NONE"
		broadcast " {@info} That's all for Secret Santa! Everyone has their person. Good luck!" if {Mythical::Santas::*} contains "NONE"
		add "NONE" to {Mythical::Santas::*} if amount of {Mythical::Santas::*} is less than 1

command /mrplayeradmin <player> [<text>] [<text>] [. <text>]:
	usage: <#CB625F>/mradmin [ TEXT ]
	description: &7Mythical Realms Admin
#	cooldown: 2 seconds
#	cooldown message: {@cooldownmessage}
	permission: commencer.inspector
	permission message: {@permissionmessage}
	trigger:
		arg-2 is "assignplot":
			arg-3 parsed as integer is an integer
			set {Mythical::Plot::%region at player%} to arg-1
			broadcast " {@info} {@mythicalrealms} Housing Plot %arg-3% is Now Owned by %arg-1%!"
		arg-2 is "removeplot":
			arg-3 parsed as integer is an integer
			broadcast " {@info} {@mythicalrealms} Housing Plot %arg-3% is Now Vacant!"
			clear {Mythical::Plot::%region at player%}
		arg-2 is "resetye":
			clear {Mythical::%arg-1%::*}
			execute arg-1 command "/s"
			wait 1 second
			execute arg-1 command "/mr"
			clear arg-1's inventory
		arg-2 is "setform":
			setForm(arg-1, arg-3)
		arg-2 is "setlevel":
			set {Mythical::%arg-1%::Level::Title} to arg-3 parsed as integer
			send "%arg-1%'s Vitality Level is Now %{Mythical::%arg-1%::Level::Title}%"
		arg-2 is "setlevelxp":
			set {Mythical::%arg-1%::Level::Progress} to arg-3 parsed as integer
			send "%arg-1%'s Vitality Level XP is Now %{Mythical::%arg-1%::Level::Progress}%"
		arg-2 is "setmana":
			set {Mythical::%arg-1%::Magic::Mana} to arg-2 parsed as integer
			send "%arg-1%'s Mana is Now %{Mythical::%arg-1%::Magic::Mana}%"
		arg-2 is "setcircuspower":
			set {Mythical::%arg-1%::Minigame::Power} to arg-2 parsed as integer
			send "%arg-1%'s Minigame Power is Now %{Mythical::%arg-1%::Minigame::Power}%"
		arg-2 is "addspell":
			arg-3 is set
			arg-4 is set
			add {Mythical::Spells::%arg-4%::%arg-3%Title} to {Mythical::%arg-1%::Magic::Spellbook::*} if {Mythical::Spells::%arg-4%::%arg-3%Title} is set
			send "%arg-1%'s Spellbook Includes %arg-3% if %{Mythical::Spells::%arg-4%::%arg-3%Title}% is Properly set"
			send "%player%&r Added %arg-3% to Your Spellbook if %{Mythical::Spells::%arg-4%::%arg-3%Title}% is Properly set" to arg-1
		arg-2 is "removespell":
			arg-3 is set
			arg-4 is set
			remove {Mythical::Spells::%arg-3%::%arg-2%Title} from {Mythical::%arg-1%::Magic::Spellbook::*} if {Mythical::Spells::%arg-3%::%arg-2%Title} is set
			send "%arg-2% Removed From %arg-1%'s Spellbook  if %{Mythical::Spells::%arg-3%::%arg-2%Title}% is set"
		arg-2 is "setquest":
			set {Mythical::%arg-1%::Quest::Progress} to arg-3 parsed as integer
			set {Mythical::%arg-1%::Quest::Main::Name} to "None"
			set {Mythical::%arg-1%::Quest::Main::Objective} to "None"
			set {Mythical::%arg-1%::Quest::Main::Title} to "Not Started"
			set {Mythical::%arg-1%::Quest::Main::Type} to "None"
			set {Mythical::%arg-1%::Quest::Main::Progress} to 0
			set {Mythical::%arg-1%::Quest::Main::Total} to 0
			send "%arg-1%'s Quest Progress # is Now %{Mythical::%arg-1%::Quest::Progress}%"
			questMaster(arg-1)
		arg-2 is "setcutscene":
			set {Mythical::%arg-1%::Cutscene::Trigger} to arg-3 parsed as integer
			send "%arg-1%'s Cutscene Progress # is Now %{Mythical::%arg-1%::Cutscene::Trigger}%" to player
			send "%arg-1%'s Cutscene Progress # is Now %{Mythical::%arg-1%::Cutscene::Trigger}%" to arg-1 

command /mradmin <text> [<text>] [. <text>] [. <text>]:
	usage: <#CB625F>/mradmin [ TEXT ]
	description: &7Mythical Realms Admin
#	cooldown: 2 seconds
#	cooldown message: {@cooldownmessage}
	permission: commencer.inspector
	permission message: {@permissionmessage}
	trigger:
		arg-1 is "resetsecretsanta":
			loop all offline players:
				send "Cleared %loop-value%" if {Mythical::%loop-value%::SecretSanta} is set
				clear {Mythical::%loop-value%::SecretSanta}
			set {Mythical::Santas::*} to "Cdestre", "_Mascarpone", "NyxRune", "EZF2011", "milk_iz_gouwd" and "YetisTheSky"
			send "%{Mythical::Santas::*}%"
		arg-1 is "checksecretsanta":
			send "%amount of {Mythical::Santas::*}%" if {Mythical::Santas::*} does not contain "NONE"
			send "0" if {Mythical::Santas::*} contains "NONE"
			loop all offline players:
				send "%loop-value%" if {Mythical::%loop-value%::SecretSanta} is set
		arg-1 is "togglestart":
			{Mythical::Toggle::Resource} is true:
				set {Mythical::Toggle} to false
				broadcast "{@commencesmp} {@mythicalrealms} is now Completely Disabled!"
				loop all players:
					execute loop-player command "/spawn"
			else:
				set {Mythical::Toggle} to true
				broadcast "{@commencesmp} {@mythicalrealms} is now Enabled and Active! /mr"
		arg-1 is "toggleresource":
			{Mythical::Toggle::Resource} is true:
				set {Mythical::Toggle::Resource} to false
				broadcast " {@info} {@mythicalrealms} Resource World is now Disabled!"
			else:
				set {Mythical::Toggle::Resource} to true
				broadcast " {@info} {@mythicalrealms} Resource World is now Enabled!"
		arg-1 is "debug" or "debugger":
			{Mythical::Debugger} is set:
				clear {Mythical::Debugger}
				broadcast "{@commencesmp} {@mythicalrealms} Debugger Disabled"
			else:
				set {Mythical::Debugger} to true
				broadcast "{@commencesmp} {@mythicalrealms} Debugger Activated"
		arg-1 is "fasttutorial":
			{Mythical::FastTutorial} is set:
				clear {Mythical::FastTutorial}
				broadcast "{@commencesmp} {@mythicalrealms} FastTutorial Disabled"
			else:
				set {Mythical::FastTutorial} to true
				broadcast "{@commencesmp} {@mythicalrealms} FastTutorial Activated"
		arg-1 is "setnpcholo":
			loop all entities in radius 100 of player:
				{Mythical::NPC::%loop-entity%::Position} is set:
					execute console command "/npc select %loop-entity's UUID%"
					execute console command "/npc hologram viewrange 10"
					execute console command "/npc hologram add %{Mythical::NPC::%loop-entity%::Position}%"
					execute console command "/npc hologram set 0 %{Mythical::NPC::%loop-entity%::Position}%"
					wait 1 tick
					execute console command "/npc hologram remove 1"
					wait 1 tick
					send "%type of loop-entity% %loop-entity% (%loop-entity's UUID%) now has hologram %{Mythical::NPC::%loop-entity%::Position}%"
			send "Action completed"
		arg-1 is "resetall":
			loop all players:
				clear {Mythical::%loop-player%::*}
				execute loop-player command "/s"
				wait 1 second
				execute loop-player command "/mr"
				clear loop-player's inventory
		arg-1 is "resetmagic":
			clear {Mythical::%player%::Magic::Wait}
		arg-1 is "resetme":
			clear {Mythical::%player%::*}
			execute player command "/s"
			wait 1 second
			execute player command "/mr"
			clear player's inventory
		arg-1 is "fixme":
			clear {Mythical::%player%::Dialogue}
			clear {Mythical::%player%::Magic::Wait}
			clear {Mythical::%player%::NPCTemp}
			clear {Mythical::%player%::UUIDNPCTemp}
		arg-1 is "resetye":
			send "%arg-1% is online"
			arg-1 parsed as player is online
			clear {Mythical::%arg-1 parsed as player%::*}
			execute arg-1 parsed as player command "/s"
			wait 1 second
			execute arg-1 parsed as player command "/mr"
			clear arg-1 parsed as player's inventory
		arg-1 is "grandreset":
			broadcast "{@mythicalrealms} is About to Reset!"
			execute console command "/dbc chat CAUTION! CAUTION! CAUTION! CommenceSMP Mythical Realms is About to Reset! CAUTION! CAUTION! CAUTION!"
			wait 5 seconds
			execute console command "/dbc chat CAUTION! CAUTION! CAUTION! CommenceSMP Mythical Realms is Resetting! CAUTION! CAUTION! CAUTION!"
			loop {Mythical::Players::*}:
				clear {Mythical::%loop-value%::*}
				broadcast "{@mythicalrealms} Cleared %loop-value% Data"
				remove loop-value from {Mythical::Players::*}
			execute console command "/dbc chat CAUTION! CAUTION! CAUTION! CommenceSMP Mythical Realms Has Reset Completely! CAUTION! CAUTION! CAUTION!"
			loop all players:
				teleport loop-player to spawn of world "SpawnHub"
		arg-1 is "playerfix":
			loop all players:
				clear {Mythical::%loop-player%::Dialogue}
				clear {Mythical::%loop-player%::Magic::Wait}
				clear {Mythical::%loop-player%::NPCTemp}
				clear {Mythical::%loop-player%::UUIDNPCTemp}
				clear {Mythical::%loop-player%::NPC::Acquaintances::*}
		arg-1 is "give":
			arg-2 is set
			arg-3 is set
			give player {Mythical::Items::%arg-2%::%arg-3%}
			send "You receieved a %{Mythical::Items::%arg-2%::%arg-3%}%"
		arg-1 is "setlevel":
			set {Mythical::%player%::Level::Title} to arg-2 parsed as integer
			send "%player%'s Vitality Level is Now %{Mythical::%player%::Level::Title}%"
		arg-1 is "setlevelxp":
			set {Mythical::%player%::Level::Progress} to arg-2 parsed as integer
			send "%player%'s Vitality Level XP is Now %{Mythical::%player%::Level::Progress}%"
		arg-1 is "setmana":
			set {Mythical::%player%::Magic::Mana} to arg-2 parsed as integer
			send "%player%'s Mana is Now %{Mythical::%player%::Magic::Mana}%"
		arg-1 is "setcircuspower":
			set {Mythical::%player%::Minigame::Power} to arg-2 parsed as integer
			send "%player%'s Minigame Power is Now %{Mythical::%player%::Minigame::Power}%"
		arg-1 is "addspell":
			arg-2 is set
			arg-3 is set
			add {Mythical::Spells::%arg-3%::%arg-2%Title} to {Mythical::%player%::Magic::Spellbook::*} if {Mythical::Spells::%arg-3%::%arg-2%Title} is set
			send "%player%'s Spellbook Includes %arg-2% if %{Mythical::Spells::%arg-3%::%arg-2%Title}% is set"
		arg-1 is "removespell":
			arg-2 is set
			arg-3 is set
