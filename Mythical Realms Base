command /dungeon [<text>]:
	aliases: /mrd
	usage: <#CB625F>/dungeon
	description: &7Mythical Realms Dungeon
#	cooldown: 1 second
#	cooldown message: {@cooldownmessage}
#	cooldown storage: {Commence::%player%::Wait}
	trigger:
		{Mythical::Toggle} is true
		{Mythical::%player%::Form::Type} is set
		player's world is {@worlds}
		set {Mythical::%player%::Minigame} to false
		clear {Mythical::%player%::Minigame::Score}
		clear {Mythical::%player%::Minigame::Timer}
		#clear {Mythical::%player%::Dungeon::Active}
		#loop 99 times:
		#	distance between block at {Mythical::Dungeon::%loop-value%::LocWait} and block under player is less than 6
		#	set {Mythical::%player%::Dungeon::Active} to loop-value
		#	stop loop
		#{Mythical::%player%::Dungeon::Active} is not set:
		#	send " {@info} You Aren't Close Enough to a Dungeon"
		#	send " {@info} Move Closer to a Dungeon Enterance and Try Again!"
		#	stop
		#else if {Mythical::Dungeon::%{Mythical::%player%::Dungeon::Active}%::Status} is not "Recruiting":
		#	send " {@info} %{Mythical::Dungeon::%{Mythical::%player%::Dungeon::Active}%::Title}% is Currently Active"
		#	send " {@info} Please Try to Join the Dungeon Later!"
		#	stop
		#stop if {Mythical::%player%::Dungeon::Active} is not set
		loop 99 times:
			distance between block at {Mythical::Dungeon::%loop-value%::LocWait} and block under player is less than 6
			set {Mythical::%{_p}%::Temp} to loop-value
		stop if {Mythical::Dungeon::%{Mythical::%{_p}%::Temp}%::Status} is "Crawling"
		set {Mythical::%player%::Dialogue} to "You're entering the %{Mythical::Dungeon::%{Mythical::%{_p}%::Temp}%::Title} ? "Dungeon"%? Yeah, good luck with that..." if {Mythical::%player%::Dialogue} is set
		set metadata tag "mrminigamedungeon" of player to chest inventory with 3 rows named "&c%{Mythical::Dungeon::%{Mythical::%{_p}%::Temp}%::Title} ? "Dungeon"%"
		guiBar(player, "mrminigamedungeon")
		set slot 13 of metadata tag "mrminigamedungeon" of player to cobweb with item flags hide enchants and hide attributes named "&c%{Mythical::Dungeon::%{Mythical::%{_p}%::Temp}%::Title} ? "Dungeon"%" with lore "&f Dungeons Are a Mix of Battles," and "&f Puzzles and Other Experiences" and "&f Completed: &7%{Mythical::%player%::Dungeon::%{Mythical::%{_p}%::Temp}%::Complete} ? "Not Completed"%" and "&7 " and "&aClick HERE to Enter Queue!"
		open (metadata tag "mrminigamedungeon" of player) to player

command /minigame [<text>]:
	aliases: /mg, /minigames
	usage: <#CB625F>/minigames
	description: &7Mythical Realms Minigames
#	cooldown: 1 second
#	cooldown message: {@cooldownmessage}
#	cooldown storage: {Commence::%player%::Wait}
	trigger:
		{Mythical::Toggle} is true
		{Mythical::%player%::Form::Type} is set
		player's world is {@worlds}
		{Mythical::%player%::Dialogue} is set:
			loop 100 times:
				send ""
			player's open inventory is not (metadata tag "mrminigames" of player)
			send " &6You:<#DCEDF4> I'd love to play some Circus Games!"
			set {Mythical::%player%::Dialogue} to "Okay! Let's play. Choose a game to start!" or "That's the spirit! Which game will you play?"
		set {Mythical::%player%::Minigame} to false
		clear {Mythical::%player%::Minigame::Score}
		clear {Mythical::%player%::Minigame::Timer}
		arg-1 contains "multi":
			set metadata tag "mrmultiminigames" of player to chest inventory with 3 rows named "{@mythicalrealms} Circus Games"
