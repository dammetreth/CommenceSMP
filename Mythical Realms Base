function sbMythical(p: player):
	{Mythical::Toggle} is true
	{_p}'s world is {@worlds}
	{Commence::%{_p}%::SideBar} is not set:
		set {Commence::%{_p}%::SideBar} to true
	chance of 50%:
		region at {_p} contains "centralhub"
		{_p}'s health is less than {_p}'s maximum health
		add 1 to {_p}'s health
		send title "" with subtitle "&a+1 &cHealth" to {_p} for 0.8 seconds
	chance of 5%:
		region at {_p} contains "centralhub"
		{Mythical::%{_p}%::Minigame::Power} < 20
		add 1 to {Mythical::%{_p}%::Minigame::Power}
		send title "" with subtitle "&a+1 &e🧪Circus Power" to {_p} for 0.8 seconds
	chance of 2%:
		region at {_p} contains "centralhub"
		{Mythical::%{_p}%::Magic::Mana} < 20
		add 1 to {Mythical::%{_p}%::Magic::Mana}
		send title "" with subtitle "&a+1 &5Mana" to {_p} for 0.8 seconds
	chance of 0.1%:
		region at {_p} contains "centralhub"
		{Mythical::%{_p}%::Magic::Infusion} < 10
		add 1 to {Mythical::%{_p}%::Magic::Infusion}
		send title "" with subtitle "&a+1 &1Infusion" to {_p} for 0.8 seconds
	{Commence::%{_p}%::SideBar} is not true:
		toggle {_p}'s fastboard to off
		stop
	{Mythical::%{_p}%::Sidebar} is true:
		set title of {_p}'s fastboard to colored "<#70797C> -&k| &r{@mythicalrealms} <#70797C>&k|&r<#70797C>-"
		set {_u} to "Not Chosen"
		set line 0 of {_p}'s fastboard to ""
		set line 1 of {_p}'s fastboard to ""
		set line 2 of {_p}'s fastboard to colored "<#D0944D> %{_p}'s display name ? {_p}%<#D0944D>'s Info"
		set line 3 of {_p}'s fastboard to colored "<#D0944D> ▪ &fForm:&7 %{Mythical::%{_p}%::Form::Class} ? {_u}% %{Mythical::%{_p}%::Form::Type} ? ""%"
		set line 4 of {_p}'s fastboard to colored "<#D0944D> ▪ &fVitality:&7 %{Mythical::%{_p}%::Level::Title} ? 0% (%{Mythical::%{_p}%::Level::Progress} ? 0%/%({Mythical::%{_p}%::Level::Title} * ({Mythical::Level::Upgrade} + round({Mythical::%{_p}%::Level::Title} * 6.3)))%)"
		set line 5 of {_p}'s fastboard to colored "<#D0944D> ▪ &fMana:&7 %{Mythical::%{_p}%::Magic::Mana} ? 0% "#+%{Mythical::%{_p}%::Magic::Infusion} ? 0%"
		set line 6 of {_p}'s fastboard to colored "<#D0944D> ▪ &fMoney:&7 $%{Mythical::%{_p}%::Money} ? 0%"
		set line 7 of {_p}'s fastboard to ""
		set line 8 of {_p}'s fastboard to colored "<#D0944D> Main Quest Goal"
		{Mythical::%{_p}%::Quest::Main::Type} is not set:
			set line 9 of {_p}'s fastboard to colored "<#D0944D> ▪ &7%{Mythical::%{_p}%::Quest::Main::Title} ? {_u}%"
			set line 10 of {_p}'s fastboard to colored "<#D0944D> ▪ &fPlayers:&7 %amount of players in world "Mythical_Realms" and "Mythical_Resources"%"
		else if {Mythical::%{_p}%::Quest::Main::Type} is not "None":
			set line 9 of {_p}'s fastboard to colored "<#D0944D> ▪ &7%{Mythical::%{_p}%::Quest::Main::Type}% %{Mythical::%{_p}%::Quest::Main::Title} ? {_u}%"
			set line 10 of {_p}'s fastboard to colored "<#D0944D> ▪ &fProgress:&7 %{Mythical::%{_p}%::Quest::Main::Progress}% / %{Mythical::%{_p}%::Quest::Main::Total}%"
		else:
			set line 9 of {_p}'s fastboard to colored "<#D0944D> ▪ &7%{Mythical::%{_p}%::Quest::Main::Title} ? {_u}%"
			set line 10 of {_p}'s fastboard to colored "<#D0944D> ▪ &fPlayers:&7 %amount of players in world "Mythical_Realms" and "Mythical_Resources"%"
		{Mythical::%{_p}%::Skill::Active} is set:
			set line 11 of {_p}'s fastboard to ""
			set line 12 of {_p}'s fastboard to colored "<#D0944D> Last Skill Info"
			set line 13 of {_p}'s fastboard to colored "<#D0944D> ▪ &f%{Mythical::%{_p}%::Skill::Active}% %{Mythical::%{_p}%::Skill::%{Mythical::%{_p}%::Skill::Active}%::Level}%"
			set line 14 of {_p}'s fastboard to colored "<#D0944D> ▪ &fProgress:&7 %{Mythical::%{_p}%::Skill::%{Mythical::%{_p}%::Skill::Active}%::Progress}% / %{Mythical::%{_p}%::Skill::%{Mythical::%{_p}%::Skill::Active}%::Level} * ({Mythical::Skill::%{Mythical::%{_p}%::Skill::Active}%::Level::Upgrade} + {Mythical::%{_p}%::Skill::%{Mythical::%{_p}%::Skill::Active}%::Level})%"
		set line 15 of {_p}'s fastboard to ""
		toggle {_p}'s fastboard to on
	stop if {Mythical::%{_p}%::Dungeon::Active} is set
	stop if {Mythical::%{_p}%::Minigame} is not false
	stop if {Mythical::%{_p}%::Tracker} is not true
	stop if {_p}'s world is not "Mythical_Realms"
	{Mythical::%{_p}%::Navigator} is true:
		{Mythical::%{_p}%::Dialogue} is not set
		{Mythical::%{_p}%::Dialogues::*} is not set
		set {_r} to "%region at {Mythical::%{_p}%::Navigator::Location}%"
		replace all " in world %{_p}'s world%" in {_r} with ""
		replace all " and centralhub" in {_r} with ""
		clear {Mythical::%{_p}%::Direction}
		set {Mythical::%{_p}%::Direction} to "north" if z-coordinate of block at {_p} is greater than z-coordinate of block at {Mythical::%{_p}%::Navigator::Location}
		set {Mythical::%{_p}%::Direction} to "south" if z-coordinate of block at {_p} is less than z-coordinate of block at {Mythical::%{_p}%::Navigator::Location}
		set {Mythical::%{_p}%::Direction} to "%{Mythical::%{_p}%::Direction} ? ""%west" if x-coordinate of block at {_p} is greater than x-coordinate of block at {Mythical::%{_p}%::Navigator::Location}
		set {Mythical::%{_p}%::Direction} to "%{Mythical::%{_p}%::Direction} ? ""%east" if x-coordinate of block at {_p} is less than x-coordinate of block at {Mythical::%{_p}%::Navigator::Location}
		send action bar "<#D0944D>Goal: &7%{Mythical::%{_p}%::Quest::Main::Type} ? "Nothing"% %{Mythical::%{_p}%::Quest::Main::Title} ? "Started Yet"% &8(%round(distance between {Mythical::%{_p}%::Navigator::Location} and {_p}) ? "Many"% blocks %{Mythical::%{_p}%::Direction} ? "away"% in %{Mythical::Region::%{_r}%::Title} ? {Mythical::%{_p}%::Navigator::Location}'s world ? "a far, far away place"%&8)" to {_p} if {Mythical::%{_p}%::Quest::Main::Total} <= 1
		send action bar "<#D0944D>Goal: &7%{Mythical::%{_p}%::Quest::Main::Type} ? "Nothing"% &a%{Mythical::%{_p}%::Quest::Main::Progress} ? 0% / %{Mythical::%{_p}%::Quest::Main::Total} ? 0% %{Mythical::%{_p}%::Quest::Main::Title} ? "Started Yet"% &8(%round(distance between {Mythical::%{_p}%::Navigator::Location} and {_p}) ? "Many"% blocks away in %{Mythical::Region::%{_r}%::Title} ? {Mythical::%{_p}%::Navigator::Location}'s world ? "a far, far away place"%&8)" to {_p} if {Mythical::%{_p}%::Quest::Main::Total} > 1
		wait 1 second
	else:
		{Mythical::%{_p}%::Quest::Main::Type} is not "None"
		{Mythical::%{_p}%::Form::Type} is set
		{Mythical::%{_p}%::Quest::Main::Title} is not "Not Started"
		loop 5 times:
			{Mythical::%{_p}%::Dialogue} is not set
			{Mythical::%{_p}%::Dialogues::*} is not set
			send action bar "<#D0944D>Goal: &7%{Mythical::%{_p}%::Quest::Main::Type} ? "Follow"% %{Mythical::%{_p}%::Quest::Main::Title} ? "Big A"%" to {_p}
			wait 1 second


