	#CHAT MESSAGES

on chat:
	set message to colored message
	{Mythical::%player%::Dialogue} is set:
		cancel event
		stop
	message contains "nigg" or "nlgg" or "n!gg" or "hitler" or "h!tler" or "nazi" or "naz!":
		cancel event
		send ""
		send "{@commence}"
		send " {@info} '%message%' Breaks Minecraft's Terms of Service!"
		send " {@info} You'll Be Muted if You Keep it Up!"
		loop all players:
			{Commence::%loop-value%::Admin} is true:
				send "%player% is using bad language in %player's world%: %message%" to loop-player
		stop
	message contains ":skull:" or ":skeleton:":
		replace all ":skull:" and ":skeleton:" in message with "☠"
	message contains ":cry:":
		replace all ":cry:" in message with "😭"
	message contains ":pray:":
		replace all ":pray:" in message with "🙏"
	message contains ":peace:":
		replace all ":peace:" in message with "✌"
	loop all players:
		message contains "%loop-player%":
			loop 2 times:
				play sound "entity.dragon_fireball.explode" or "block.anvil.land" or "block.bell.use" or "block.bell.resonate" or "block.conduit.activate" at volume 100 at pitch 17 to loop-player
			stop loop
	rankCheck(player)
	
	player's world is "Survival2":
		{Lifer::%player%::Age} is less than 5:
			set chat format to "&8&lL &9%{Lifer::%player%::First}% &8%{Lifer::%player%::Last}%: &a%random element of {BabyTalk::*}%"
			stop
		set chat format to "&8&lL &9%{Lifer::%player%::First}% &8%{Lifer::%player%::Last}%: <#DCEDF4>%message%"
	else:
		set chat format to "%{Commence::%player%::Badges} ? " "%%player's display name ? player%: <#DCEDF4>%message%"
		set chat format to "%{Commence::%player%::Badges} ? " "%<#1B1718>%player%<#B16216>: %message%" if {Mythical::Holiday} is "Halloween"
		set chat format to "%{Commence::%player%::Badges} ? " "%<#760102>%player%<#00680A>: %message%" if {Mythical::Holiday} is "Christmas"
		set chat format to "%{Commence::%player%::Badges} ? " "%<#68FF70>%player%<#68FF70>: %message%" if {Mythical::Holiday} is "Saint Patrick's Day"
		set chat format to "%{Commence::%player%::Badges} ? " "%<#FF8E8E>%player%<#DCEDF4>: %message%" if {Mythical::Holiday} is "Valentine's Day"
		#add chat format to {Commence::Chat::*}
		#remove last element of {Commence::Chat::*} from {Commence::Chat::*} if amount of {Commence::Chat::*} is more than 99

