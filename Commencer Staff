command /assignbadge <player> <text>:
	usage: <#CB625F>/assignbadge [ PLAYER ] [ BADGE ]
	description: &7Assign Badges to Players!
	permission: commencer.admin
	permission message: {@permissionmessage}
	cooldown message: {@cooldownmessage}
	cooldown: 10 seconds
	trigger:
		if amount of {Commence::%arg-1%::Badges::*} is more than 2:
			send "%arg-1% has enough badges!" to player
			stop
		{Commence::Badges::%arg-2%::Symbol} is set:
			send "You Gave %arg-1% a Badge! %{Commence::Badges::%arg-2%::Symbol}% %{Commence::Badges::%arg-2%::Description}%" to player
			play sound "entity.player.levelup" at arg-1
			send title "<#00C889>YOU EARNED A BADGE!" with subtitle "<#00C889>%{Commence::Badges::%arg-2%::Symbol}%" to arg-1
			send "<#00C889> YOU EARNED A BADGE! %{Commence::Badges::%arg-2%::Symbol}%" to arg-1
			send "<#00C889>%{Commence::Badges::%arg-2%::Symbol}% %{Commence::Badges::%arg-2%::Description}%" to arg-1
			if {Commence::%arg-1%::Badges} is set:
				set {Commence::%arg-1%::Badges} to "%{Commence::%arg-1%::Badges}%%{Commence::Badges::%arg-2%::Symbol}%"
			else:
				set {Commence::%arg-1%::Badges} to "%{Commence::Badges::%arg-2%::Symbol}%"
		arg-2 contains "clear":
			clear {Commence::%arg-1%::Badges::*}
			clear {Commence::%arg-1%::Badges}
			send " {@info} All Badges Cleared for %arg-1%" to arg-1

command /bc <text>:
	aliases: /broadcast, /bcs, /broadcasts
	usage: <#CB625F> /broadcast [ MESSAGE ]
	description: &7 Broadcasts a message to the server
	permission: commencer.admin
	cooldown: 1 second
	permission message: {@permissionmessage}
	cooldown message: {@cooldownmessage}
	trigger:
		broadcast "&7 {@commencesmp}&fGODS<#3988A3>: %argument%"

command /updatestop:
	usage: <#CB625F> /updatestop
	description: &7 Restarts the server automatically
	permission: commencer.admin
	cooldown: 2 minutes
	permission message: {@permissionmessage}
	cooldown message: {@cooldownmessage}
	trigger:
		if {Commence::%player%::Admin} is true:
			broadcast ""
			broadcast "    {@commencesmp} is Restarting!"
			broadcast "&4     Restarting in 1 minute"
			broadcast "&4      Join again! &3play.CommenceSMP.com"
			broadcast ""
			wait 30 seconds
			broadcast ""
			broadcast "    {@commencesmp} is Restarting!"
			broadcast "&4     Restarting in 30 seconds"
			broadcast "&4      Join again! &3play.CommenceSMP.com"
			broadcast ""
			wait 20 seconds
			set {_tir} to 10
			loop 10 times:
				remove 1 from {_tir}
				broadcast ""
				broadcast "    {@commencesmp} is Restarting!"
				broadcast "&4     Restarting in %{_tir}% seconds"
				broadcast "&4      Join again! &3play.CommenceSMP.com"
				broadcast ""
				wait 1 second
			wait 10 seconds
			execute console command "/restart"

command /setspawn [<world>]:
	aliases: /ss
	usage: <#CB625F> /setspawn
	description: &7 Sets the spawn for that world
	permission: commencer.admin
	cooldown: 1 second
	permission message: {@permissionmessage}
	cooldown message: {@cooldownmessage}
	trigger:
		if arg-1 is set:
			set {_tw} to arg-1
		else:
			set {_tw} to player's world
		set {Spawn::%{_tw}%} to player's location
		set world "%{_tw}%"'s spawn to player's location
		send "{@owner}"
		send ""
		send "&7   You set the spawn point of world <#00C889>&l%{_tw}%&7 to <#00C889>&l%{Spawn::%{_tw}%}%&7!"
		send ""

command /updatespawn:
	usage: <#CB625F>/updatespawn
	description: &7Edit SpawnHub
	permission: commencer.admin
	cooldown: 1 second
	permission message: {@permissionmessage}
	cooldown message: {@cooldownmessage}
	trigger:
		{Commence::%player%::AdminEdit} is not true
		set {Commence::%player%::AdminEdit} to true
		send "{@owner}"
		send " {@info} You May Edit Spawn for 1 Minute"
		send ""
		wait 1 minute
		send "{@owner}"
		send " {@info} You're Done Editing Spawn"
		send ""
		clear {Commence::%player%::AdminEdit}


