command /fly [<player>]:
	usage: <#CB625F> /fly [ PLAYER ]
	description: &7 Toggles fly mode
	permission: commencer.inspector
	cooldown: 10 seconds
	permission message: {@permissionmessage}
	cooldown message: {@cooldownmessage}
	trigger:
		player's world is not "Survival" or "Survival3" or "CommenceCity":
			send "<#CB625F>   You can't fly in this game mode"
			stop
		arg-1 is set:
			arg-1's flight mode is true:
				send ""
				send "{@inspector}"
				send "&7   Disabled flight mode for %arg-1's display name%"
				send "" to arg-1
				send "{@inspector}" to arg-1
				send "&7   %player's display name% &7disabled flight mode for you" to arg-1
				set arg-1's flight mode to false
			else:
				send ""
				send "{@inspector}"
				send "&7   Enabled flight mode for %arg-1's display name%"
				send "" to arg-1
				send "{@inspector}" to arg-1
				send "&7   %player's display name% &7enabled flight mode for you" to arg-1
				set arg-1's flight mode to true
		else:
			player's flight mode is true:
				send ""
				send "{@inspector}"
				send "&7   Disabled flight mode for %player's display name%"
				set player's flight mode to false
			else:
				send ""
				send "{@inspector}"
				send "&7   Enabled flight mode for %player's display name%"
				set player's flight mode to true

command /kick <player> [<text>]:
	usage: <#CB625F> /kick [ PLAYER ] [ REASON ]
	description: &7 Kicks a player
	permission: commencer.inspector
	cooldown: 10 seconds
	permission message: {@permissionmessage}
	cooldown message: {@cooldownmessage}
	trigger:
		{Commence::%arg-1%::Rank::Value} is more than {Commence::%player%::Rank::Value}:
			stop
		arg-2 is set:
			send ""
			send "{@inspector}"
			send "<#CB625F>   You kicked %arg-1's display name%<#CB625F> for %arg-2%&7"
			send "" to arg-1
			send "{@inspector}" to arg-1
			send "<#CB625F>   %player's display name% <#CB625F>kicked you for %arg-2%&7" to arg-1
			kick arg-1 because arg-2
		else:
			send ""
			send "{@inspector}"
			send "<#CB625F>   You kicked %arg-1's display name%<#CB625F>"
			kick arg-1

command /ban <offline player> [<text>]:
	aliases: /banip
	usage: <#CB625F> /ban [ PLAYER ] [ REASON ] ~ TIME IN MINUTES ~
	description: &7 Bans a player
	permission: commencer.inspector
	cooldown: 10 seconds
	permission message: {@permissionmessage}
	cooldown message: {@cooldownmessage}
	trigger:
		arg-1 is banned:
			send ""
			send "{@inspector}"
			send "<#CB625F>   %arg-1's display name ? arg-1%<#CB625F> is already banned"
		{Commence::%arg-1%::Rank::Value} is more than {Commence::%player%::Rank::Value}:
			stop
		arg-2 is set:
			send ""
			send "{@inspector}"
			send "<#CB625F>   You banned %arg-1's display name ? arg-1%<#CB625F> for %arg-2%&7"
			send "<#CB625F>   To unban, type <#CB625F>/unban %arg-1's display name ? arg-1%"
			send "" to arg-1
			send "{@inspector}" to arg-1
			send "<#CB625F>   You have been banned for %arg-2%&7" to arg-1
			ban arg-1 because arg-2
			wait 1 second
			kick arg-1 because arg-2
		else:
			send ""
			send "{@inspector}"
			send "<#CB625F>   You banned %arg-1's display name ? arg-1%<#CB625F>&7"
			send "<#CB625F>   To unban, type <#CB625F>/unban %arg-1's display name ? arg-1%"
			ban arg-1 because "You Are Not Permitted to Join CommenceSMP"

