
function castAirSpell(p: player):
#	send "{@spelluse} SPELL INITIATION" to {_p}
	play sound "minecraft:entity.phantom.flap" at volume 1 at pitch 1.3 at {_p}'s location
	play sound "minecraft:entity.ender_dragon.flap" at volume 0.6 at pitch 1.5 at {_p}'s location
	loop {Mythical::%{_p}%::MagicPower} + 30 ? 30 times:
		set {_y} to loop-value * 0.1 # spiral climbs upward
		set {_angle} to loop-value * 18 # rotation speed
		set {_x} to cos({_angle}) * 1
		set {_z} to sin({_angle}) * 1
		draw random integer between 1 and 10 of cloud at location of {_p} offset by vector({_x}, {_y}, {_z})
		draw random integer between 1 and 10 of gust at location of {_p} offset by vector({_x}, {_y}, {_z})
		wait 1 tick
	play sound "minecraft:item.elytra.flying" at volume 0.9 at pitch 1.4 at {_p}'s location
	draw 40 of gust at location of {_p} offset by vector(0, 3, 0)
	wait 2 ticks

#			send "{@spelluse} SPELL POWER" to {_p}
	uncolored {Mythical::%{_p}%::Magic::Spell} contains "Gust Step":
		play sound "minecraft:entity.player.attack.knockback" at volume 1 at pitch 1.2 at {_p}'s location
		push {_p} forwards with force random number between 0.1 and 2
		loop 12 times:
			{_p}'s target is a mob or a player
			push {_p}'s target up with force random number between 0.1 and 0.5
			make {_p} damage {_p}'s target by 0.33 + {Mythical::%{_p}%::MagicPower} ? 0
			draw 44 of gust loop-value * 0.33 blocks above {_p}'s target
			draw 16 of cloud loop-value * 0.33 blocks above {_p}'s target
			wait 0.25 seconds
			
	else if uncolored {Mythical::%{_p}%::Magic::Spell} contains "Wind Shield":
		play sound "minecraft:entity.player.attack.knockback" at volume 1 at pitch 1.2 at {_p}'s location
		#clear {Mythical::%{_p}%::Blocks::*}
		#add block 1 blocks above block in front of {_p} to {Mythical::%{_p}%::Blocks::*} if block 1 blocks above block in front of {_p} is air
		#add block 2 blocks above block in front of {_p} to {Mythical::%{_p}%::Blocks::*} if block 2 blocks above block in front of {_p} is air
		#loop all entities in radius 3 of {_p}:
		#	stop if loop-entity contains painting or item frame or ladder
		#{Mythical::%{_p}%::MagicPower} is more than 1:
		#	add block 1 blocks above block to the right of block in front of {_p} to {Mythical::%{_p}%::Blocks::*} if block 1 blocks above block to the right of block in front of {_p} is air
		#	add block 2 blocks above block to the right of block in front of {_p} to {Mythical::%{_p}%::Blocks::*} if block 2 blocks above block to the right of block in front of {_p} is air
		#{Mythical::%{_p}%::MagicPower} is more than 2:
		#	add block 1 blocks above block to the left of block in front of {_p} to {Mythical::%{_p}%::Blocks::*} if block 1 blocks above block to the left of block in front of {_p} is air
		#	add block 2 blocks above block to the left of block in front of {_p} to {Mythical::%{_p}%::Blocks::*} if block 2 blocks above block to the left of block in front of {_p} is air
		#loop {Mythical::%{_p}%::Blocks::*}:
		#	play sound "minecraft:entity.player.attack.knockback" at volume 1 at pitch 0.1 at {_p}'s location
		#	draw 5 of sweep_attack at loop-value
		#	set block at loop-value to barrier
		#	draw 3 of snowflake at loop-value
		#	wait 3 tick
		#wait 4 seconds
		#loop {Mythical::%{_p}%::Blocks::*}:
		#	play sound "minecraft:entity.player.attack.knockback" at volume 1 at pitch 0.1 at {_p}'s location
		#	draw 5 of sweep_attack at loop-value
		#	set block at loop-value to air
		#	draw 3 of snowflake at loop-value
		#	wait 3 tick
		spawn breeze at {_p}:
			set gravity of entity to false
			set ai of entity to false
			set entity's scale attribute to 2
		make last spawned breeze invisible
		set {Mythical::%{_p}%::Magic::Entity} to last spawned breeze
		loop round({Mythical::%{_p}%::MagicPower} * 3) times:
			teleport {Mythical::%{_p}%::Magic::Entity} to {_p}
			wait 1 tick
		kill {Mythical::%{_p}%::Magic::Entity}
		clear {Mythical::%{_p}%::Magic::Entity}

	else if uncolored {Mythical::%{_p}%::Magic::Spell} contains "Sky Vault":
		play sound "minecraft:entity.phantom.flap" at volume 1 at pitch 1.3 at {_p}'s location
		play sound "minecraft:entity.ender_dragon.flap" at volume 0.6 at pitch 1.5 at {_p}'s location
		play sound "minecraft:entity.player.attack.knockback" at volume 1 at pitch 1.2 at {_p}'s location
		push {_p} upwards with force random number between {Mythical::%{_p}%::MagicPower} and 2
		draw 5 of sweep_attack at {_p}
		loop 20 times:
			draw 3 of block particle using snowflake at {_p}
			wait 1 tick
			
	else if uncolored {Mythical::%{_p}%::Magic::Spell} contains "Razor Wind":
		play sound "minecraft:entity.iron_golem.attack" at volume 1.1 at pitch 0.8 at {_p}'s location
		loop 12 times:
			draw 16 of cloud loop-value * 0.11 blocks above {_p}'s target
			draw loop-value of gust loop-value * 0.33 meters in front of {_p}'s head
			draw loop-value of sweep_attack loop-value * 0.5 meters in front of {_p}'s head
			{_p}'s target is a mob or a player:
				make {_p} damage {_p}'s target by 0.3 + {Mythical::%{_p}%::MagicPower} ? 0
			wait 5 ticks
			
	else if uncolored {Mythical::%{_p}%::Magic::Spell} contains "Featherfall Blade":
		play sound "minecraft:entity.iron_golem.attack" at volume 1.1 at pitch 0.8 at {_p}'s location
		loop 50 times:
			draw 5 of cloud loop-value * 0.03 blocks above {_p}'s head
			wait 2 ticks

	else if uncolored {Mythical::%{_p}%::Magic::Spell} contains "Cyclone Pull":
		play sound "minecraft:entity.iron_golem.attack" at volume 1.1 at pitch 0.8 at {_p}'s location
		play sound "minecraft:entity.ender_dragon.flap" at volume 0.6 at pitch 1.5 at {_p}'s location
		play sound "minecraft:entity.player.attack.knockback" at volume 1 at pitch 1.2 at {_p}'s location
		loop all entities in radius 8 of {_p}:
			loop-entity is a monster or mob:
				push loop-entity right with force ({Mythical::%{_p}%::MagicPower} ? 0.1) * 10
				push loop-entity left with force ({Mythical::%{_p}%::MagicPower} ? 0.1) * 10
				push loop-entity backwards with force ({Mythical::%{_p}%::MagicPower} ? 0.1) * 10
				push loop-entity towards {_p} with force ({Mythical::%{_p}%::MagicPower} ? 0.1) * 10
				damage loop-entity by 0.3 + {Mythical::%{_p}%::MagicPower} ? 0
			loop (distance between {_p} and loop-entity) times:
				draw random integer between 10 and 20 of cloud 1 meter above loop-entity
				wait 1 tick

	else:
		send "{@spellfail}" to {_p}
		clear {Mythical::%{_p}%::Magic::Wait}
		stop
