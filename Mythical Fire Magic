
function castFireSpell(p: player):
#	send "{@spelluse} SPELL INITIATION" to {_p}
	play sound "minecraft:entity.blaze.shoot" at volume 1 at pitch 1 at {_p}'s location
	play sound "minecraft:block.fire.ambient" at volume 0.8 at pitch 1.2 at {_p}'s location
	play sound "minecraft:entity.ghast.shoot" at volume 0.6 at pitch 1.4 at {_p}'s location
	loop {Mythical::%{_p}%::MagicPower} + 12 ? 12 times:
		set {_x} to random number between -1.5 and 1.5
		set {_y} to random number between 0 and 2
		set {_z} to random number between -1.5 and 1.5
		draw random integer between 6 and 12 of flame at location of {_p} offset by vector({_x}, {_y}, {_z})
		draw random integer between 4 and 8 of smoke at location of {_p} offset by vector({_x} * 0.7, {_y}, {_z} * 0.7)
		draw random integer between 5 and 10 of dust_color_transition using dustTransition(orange, red, 2) at location of {_p} offset by vector({_x}, {_y}, {_z})
		wait 2 ticks
	play sound "minecraft:entity.generic.explode" at volume 1.2 at pitch 0.9 at {_p}'s location
	play sound "minecraft:entity.dragon_fireball.explode" at volume 1 at pitch 1.3 at {_p}'s location
	draw 80 of explosion_emitter at {_p}
	draw 50 of flame at {_p}
	draw 30 of lava at {_p}
	draw 40 of large_smoke at {_p}
	wait 2 ticks

#			send "{@spelluse} SPELL POWER" to {_p}
	uncolored {Mythical::%{_p}%::Magic::Spell} contains "Flame Bolt":
		play sound "minecraft:item.firecharge.use" at volume 1 at pitch 1 at {_p}'s location
		play sound "minecraft:entity.blaze.shoot" at volume 1 at pitch 1.3 at {_p}'s location
		make {_p} shoot fireball at speed random number between 0.3 and 1.5
		draw 30 of flame at {_p}
		draw 20 of lava at {_p}
		draw 12 of smoke at {_p}

	else if uncolored {Mythical::%{_p}%::Magic::Spell} contains "Hellstep":
		play sound "minecraft:item.firecharge.use" at volume 1 at pitch 1 at {_p}'s location
		play sound "minecraft:entity.blaze.shoot" at volume 1 at pitch 1.3 at {_p}'s location
		clear {Mythical::%{_p}%::Blocks::*}
		loop 4 times:
			push {_p} forwards with force 0.5
			add block 1 block behind {_p} to {Mythical::%{_p}%::Blocks::*} if block 1 meter behind {_p} is air
			draw random integer between 10 and 20 of block particle using fire 1 meter behind {_p}
			set block 1 block behind {_p} to fire if block 1 meter behind {_p} is air
			wait 7 ticks
		loop {Mythical::%{_p}%::Blocks::*}:
			set block at loop-value to air
			push {_p} 1 meter forward
			wait 7 ticks

	else if uncolored {Mythical::%{_p}%::Magic::Spell} contains "Combust":
		play sound "minecraft:item.firecharge.use" at volume 1 at pitch 1 at {_p}'s location
		play sound "minecraft:entity.blaze.shoot" at volume 1 at pitch 1.3 at {_p}'s location
		loop all entities in radius 5 of {_p}:
			loop-entity is a player or monster or mob
			ignite loop-entity for 3 seconds
			loop (distance between {_p} and loop-entity) times:
				draw random integer between 10 and 20 of block particle using fire 1 meter above loop-entity
				wait 1 tick

	else if uncolored {Mythical::%{_p}%::Magic::Spell} contains "Blazing Ring":
		play sound "minecraft:item.firecharge.use" at volume 1 at pitch 1 at {_p}'s location
		play sound "minecraft:entity.blaze.shoot" at volume 1 at pitch 1.3 at {_p}'s location
		loop 12 times:
			set {_y} to loop-value * 0.05 # spiral climbs upward
			set {_angle} to loop-value * 18 # rotation speed
			set {_x} to cos({_angle}) * 1
			set {_z} to sin({_angle}) * 1
			draw random integer between 1 and 10 of flame at location of {_p}'s target offset by vector({_x}, {_y}, {_z})
			draw random integer between 1 and 10 of smoke at location of {_p}'s target offset by vector({_x}, {_y}, {_z})
			make {_p} damage {_p}'s target by 0.6 + {Mythical::%{_p}%::MagicPower} ? 0 if {_p}'s target is a mob or a player
			
	else if uncolored {Mythical::%{_p}%::Magic::Spell} contains "Firebrand":
		play sound "minecraft:item.firecharge.use" at volume 1 at pitch 1 at {_p}'s location
		play sound "minecraft:entity.blaze.shoot" at volume 1 at pitch 1.3 at {_p}'s location
		loop 50 times:
			draw 5 of flame loop-value * 0.03 blocks above {_p}'s head
			wait 2 ticks

	else if uncolored {Mythical::%{_p}%::Magic::Spell} contains "Wild Inferno":
		play sound "minecraft:item.firecharge.use" at volume 1 at pitch 1 at {_p}'s location
		play sound "minecraft:entity.blaze.shoot" at volume 1 at pitch 1.3 at {_p}'s location
		set {_b} to a random element out of blocks in radius 3 of {_p}
		set {_b} to block random integer between 1 and 3 blocks below {_b} if {_b} is air
		loop random integer between 1 and 4 times:
			draw 18 of flame loop-value-2 * 0.25 blocks above {_b}
			draw 12 of smoke loop-value-2 * 0.25 blocks above {_b}
			draw 14 of block particle using magma block loop-value-2 * 0.25 blocks above {_b}
			draw 10 of dust_color_transition using dustTransition(red, orange, 3) loop-value-2 * 0.25 blocks above {_b}
			loop all entities in radius 1 of {_b}:
				make {_p} damage loop-entity by 0.6 + {Mythical::%{_p}%::MagicPower} ? 0
			wait 1 tick

	else:
		send "{@spellfail}" to {_p}
		clear {Mythical::%{_p}%::Magic::Wait}
		stop
