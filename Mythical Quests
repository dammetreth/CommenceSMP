
options:
	story:&8 <##70797C>(<##CC3B3B>&l!<##70797C>) <##D0944D>M<##D39650>y<##D89A52>t<##DD9D54>h<##E2A156>i<##E8A458>c<##EDA85A>a<##F2AC5C>l <##F7AF5D>R<##FCB35F>e<##FFB766>a<##FFB96B>l<##FFBC70>m<##FFBE75>s <##70797C>(<##CC3B3B>&l!<##70797C>)
	info:<##70797C>(<##CC3B3B>&l!<##70797C>)<##CB625F>
	worlds: "Mythical_Realms" or "Mythical_Resources"

function questMaster(p: player):
	{Mythical::Toggle} is true
	{_p}'s world is "Mythical_Realms"
	{Mythical::%{_p}%::Cutscene::Player} is not set
	{Mythical::%{_p}%::Dialogue} is not set
	{Mythical::%{_p}%::Minigame} is not true
	{Mythical::%{_p}%::Quest::Main::Reward} is true:
		set {Mythical::%{_p}%::Quest::Main::Reward} to false
		#send title "" with subtitle "&fYou Completed All Main Quests So Far!" to {_p} for 5 seconds
		send "&7 " to {_p}
		send "{@story}" to {_p}
		send " {@info}<#7DF29C> +<#D0944D>QUEST COMPLETE &7<#7DF29C>You %{Mythical::%{_p}%::Quest::Main::Type}%<#7DF29C>ed %{Mythical::%{_p}%::Quest::Main::Title}%<#7DF29C>!" to {_p} if {Mythical::%{_p}%::Quest::Main::Type} is not "Talk to"
		send " {@info}<#7DF29C> +<#D0944D>QUEST COMPLETE &7<#7DF29C>You Talked to %{Mythical::%{_p}%::Quest::Main::Title}%<#7DF29C>!" to {_p} if {Mythical::%{_p}%::Quest::Main::Type} is "Talk to"
		send " {@info}<#7DF29C> Here's Your Rewards:" to {_p}
		set {Mythical::%{_p}%::Navigator} to false
		clear {Mythical::%{_p}%::Navigator::Location}
		clear {Mythical::%{_p}%::Quest::Journal::%{Mythical::%{_p}%::Quest::Progress}%::*}
		add "Quest %{Mythical::%{_p}%::Quest::Progress}% in %{Mythical::%{_p}%::Quest::Main::Name}%" to {Mythical::%{_p}%::Quest::Journal::%{Mythical::%{_p}%::Quest::Progress}%::*}
		add "Objective: %{Mythical::%{_p}%::Quest::Main::Objective}%" to {Mythical::%{_p}%::Quest::Journal::%{Mythical::%{_p}%::Quest::Progress}%::*}
		add "Goal: %{Mythical::%{_p}%::Quest::Main::Type}% %{Mythical::%{_p}%::Quest::Main::Title}%" to {Mythical::%{_p}%::Quest::Journal::%{Mythical::%{_p}%::Quest::Progress}%::*}
		add "Goal Progress: %{Mythical::%{_p}%::Quest::Main::Progress}%/%{Mythical::%{_p}%::Quest::Main::Total}%" to {Mythical::%{_p}%::Quest::Journal::%{Mythical::%{_p}%::Quest::Progress}%::*}
		add "Status: Completed" to {Mythical::%{_p}%::Quest::Journal::%{Mythical::%{_p}%::Quest::Progress}%::*}
		add "" to {Mythical::%{_p}%::Quest::Journal::%{Mythical::%{_p}%::Quest::Progress}%::*}
		add 1 to {Mythical::%{_p}%::Quest::Progress}
		set {Mythical::%{_p}%::Quest::Main::Title} to "Not Started"
		set {Mythical::%{_p}%::Quest::Main::Type} to "None"
		set {Mythical::%{_p}%::Quest::Main::Progress} to 0
		set {Mythical::%{_p}%::Quest::Main::Total} to 0
		set {_d} to random integer between 1 and {Mythical::%{_p}%::Level::Title}
		add {_d} to {Mythical::%{_p}%::Money}
		send " {@info}<#7DF29C> +<#3988A3>Money! &a+$%{_d}%" to {_p}
		set {_m} to random integer between 1 and {Mythical::%{_p}%::Level::Title}
		send " {@info}<#7DF29C> +<#3988A3>Mana! <#855EC9>+🧪%{_m}%" to {_p}
		set {_x} to random integer between 1 and {Mythical::%{_p}%::Quest::Progress} + {Mythical::%{_p}%::Level::Title}
		add {_x} to {Mythical::%{_p}%::Level::Progress}
		send " {@info}<#7DF29C> Here's a Breakdown of Your Level!" to {_p}
		send " {@info}<#7DF29C> +<#3988A3>Your Vitality Level is %{Mythical::%{_p}%::Level::Title} ? 0%" to {_p}
		send " {@info}<#7DF29C> +<#3988A3>Experience Until Next Level! <#D0944D>%{Mythical::%{_p}%::Level::Progress} ? 0%/%({Mythical::%{_p}%::Level::Title} * ({Mythical::Level::Upgrade} + round({Mythical::%{_p}%::Level::Title} * 6.3)))%" to {_p}
		play sound "entity.player.levelup" at volume 100 at pitch 10 to {_p}
		play sound "entity.puffer_fish.death" at volume 100 at pitch 100 to {_p}
		{Mythical::%{_p}%::Quest::Progress} is 5:
			{_p}'s inventory does not contain {Mythical::Items::Wands::StarterWand}:
				give {_p} 1 of {Mythical::Items::Wands::StarterWand}
			set {Mythical::%{_p}%::Magic} to true
			send " {@info}<#7DF29C> You Learned How to Use Magic! Here's a Starter Wand!" to {_p}
		{Mythical::%{_p}%::Quest::Progress} is 7:
			give {_p} random integer between 4 and 16 of bread named "&eBumbeloaf's Bites"
			send " {@info}<#7DF29C> You got some &eBumbeloaf's Bites<#7DF29C>!" to {_p}
	{Mythical::%{_p}%::Quest::Main::Type} is "Visit":
		broadcast "%distance between {Mythical::%{_p}%::Navigator::Location}'s location and {_p}'s location% DISTANCE" if {Mythical::Debugger} is true
		{Mythical::%{_p}%::Navigator} is true
		{Mythical::%{_p}%::Navigator::Location} is set
		distance between {Mythical::%{_p}%::Navigator::Location}'s location and {_p}'s location is less than 10
		set {Mythical::%{_p}%::Quest::Main::Reward} to true
	{Mythical::%{_p}%::Quest::Main::Type} is "Play":
		{Mythical::%{_p}%::Quest::Main::Condition} is false
		set {Mythical::%{_p}%::Quest::Main::Reward} to true
	{Mythical::%{_p}%::Quest::Main::Type} is "Conquer":
		{Mythical::%{_p}%::Quest::Main::Condition} is false
		set {Mythical::%{_p}%::Quest::Main::Reward} to true
	{Mythical::%{_p}%::Quest::Main::Type} is "Talk to":
		{Mythical::%{_p}%::Quest::Main::Progress} >= {Mythical::%{_p}%::Quest::Main::Total}
		set {Mythical::%{_p}%::Quest::Main::Reward} to true
	{Mythical::%{_p}%::Quest::Main::Type} is "Kill":
		uncolored {Mythical::%{_p}%::Quest::Main::Title} contains "Zombie":
			set {Mythical::%{_p}%::Navigator::Location} to nearest zombie relative to {_p}
		else if uncolored {Mythical::%{_p}%::Quest::Main::Title} contains "Skeleton":
			set {Mythical::%{_p}%::Navigator::Location} to nearest skeleton relative to {_p}
		else if uncolored {Mythical::%{_p}%::Quest::Main::Title} contains "Spider":
			set {Mythical::%{_p}%::Navigator::Location} to nearest spider relative to {_p}
		else if uncolored {Mythical::%{_p}%::Quest::Main::Title} contains "Creeper":
			set {Mythical::%{_p}%::Navigator::Location} to nearest creeper relative to {_p}
		{Mythical::%{_p}%::Quest::Main::Progress} >= {Mythical::%{_p}%::Quest::Main::Total}
		set {Mythical::%{_p}%::Quest::Main::Reward} to true
	{Mythical::%{_p}%::Quest::Main::Title} is "Not Started"
	execute console command "/mradmin setnpcdata"

	# PART I: A Soulful Enterance
	#I1: Big A Party
	#I1: Questionton
	#I1: Form Chambers
	#I2: Gupta & Jenkin
	
	# PART II: An Enchanting Oasis
	{Mythical::%{_p}%::Quest::Progress} is 1:
		set {Mythical::%{_p}%::Navigator} to true
		set {Mythical::%{_p}%::Navigator::Location} to location(-584, 64, 1242, world("Mythical_Realms"))
		set {Mythical::%{_p}%::Quest::Main::Condition} to false
		clear {Mythical::%{_p}%::Quest::Main::Conditions::*}
		set {Mythical::%{_p}%::Quest::Main::Name} to "Part II: An Enchanting Oasis"
		set {Mythical::%{_p}%::Quest::Main::Objective} to "Visit Mythical Realms Abode of Mysterious Things"
		set {Mythical::%{_p}%::Quest::Main::Title} to "&aMythical Realms Abode"
		set {Mythical::%{_p}%::Quest::Main::Type} to "Visit"
		set {Mythical::%{_p}%::Quest::Main::Progress} to 0
		set {Mythical::%{_p}%::Quest::Main::Total} to 1
	else if {Mythical::%{_p}%::Quest::Progress} is 2:
		set {Mythical::%{_p}%::Navigator} to true
		set {Mythical::%{_p}%::Navigator::Location} to {Mythical::NPC::Flinket}'s location
		set {Mythical::%{_p}%::Quest::Main::Condition} to false
		set {Mythical::%{_p}%::Quest::Main::Conditions::*} to {Mythical::NPC::Flinket}
		set {Mythical::%{_p}%::Quest::Main::Name} to "Part II: An Enchanting Oasis"
		set {Mythical::%{_p}%::Quest::Main::Objective} to "Try to Obtain Top-Notch Equipment"
		set {Mythical::%{_p}%::Quest::Main::Title} to {Mythical::NPC::%{Mythical::NPC::Flinket}%::FullName}'s name ? "&aFlinket Brogg"
		set {Mythical::%{_p}%::Quest::Main::Type} to "Talk to"
		set {Mythical::%{_p}%::Quest::Main::Progress} to 0
		set {Mythical::%{_p}%::Quest::Main::Total} to 1
	
	# PART III: The Prism Promenade
	else if {Mythical::%{_p}%::Quest::Progress} is 3:
		#CUTSCENE 3 - Bonewart's Introduction
		cutsceneMaster({_p}, "None", 3, "Story")
		#Bonewart and Cackle Appear
		#Bonewart Threatens He's Looking for Specific Types of People (Cultist Formtypes)
		#Bonewart and Cackle Get in a Comical Argument
		#Bonewart and Cackle Poof
		#Flinket Freaks Out
		#Big A's Voice Tells You to Come See Him, but Learn Magic First
		set {Mythical::%{_p}%::Navigator} to true
		set {Mythical::%{_p}%::Navigator::Location} to location(-599, 68, 1280, world("Mythical_Realms"))
		set {Mythical::%{_p}%::Quest::Main::Condition} to false
		clear {Mythical::%{_p}%::Quest::Main::Conditions::*}
		set {Mythical::%{_p}%::Quest::Main::Name} to "Part III: The Prism Promenade"
		set {Mythical::%{_p}%::Quest::Main::Objective} to "Learn About School of Magic"
		set {Mythical::%{_p}%::Quest::Main::Title} to "&aSchool of Magic"
		set {Mythical::%{_p}%::Quest::Main::Type} to "Visit"
		set {Mythical::%{_p}%::Quest::Main::Progress} to 0
		set {Mythical::%{_p}%::Quest::Main::Total} to 1
	else if {Mythical::%{_p}%::Quest::Progress} is 4:
		set {Mythical::%{_p}%::Navigator} to true
		set {Mythical::%{_p}%::Navigator::Location} to {Mythical::NPC::Whick}'s location if uncolored {Mythical::%{_p}%::Form::Type} contains "Air"
		set {Mythical::%{_p}%::Navigator::Location} to {Mythical::NPC::Esmund}'s location if uncolored {Mythical::%{_p}%::Form::Type} contains "Fire"
		set {Mythical::%{_p}%::Navigator::Location} to {Mythical::NPC::Ajabadada}'s location if uncolored {Mythical::%{_p}%::Form::Type} contains "Water"
		set {Mythical::%{_p}%::Navigator::Location} to {Mythical::NPC::Griv}'s location if uncolored {Mythical::%{_p}%::Form::Type} contains "Earth"
		set {Mythical::%{_p}%::Quest::Main::Conditions::*} to {Mythical::NPC::Whick} if uncolored {Mythical::%{_p}%::Form::Type} contains "Air"
		set {Mythical::%{_p}%::Quest::Main::Conditions::*} to {Mythical::NPC::Esmund} if uncolored {Mythical::%{_p}%::Form::Type} contains "Fire"
		set {Mythical::%{_p}%::Quest::Main::Conditions::*} to {Mythical::NPC::Ajabadada} if uncolored {Mythical::%{_p}%::Form::Type} contains "Water"
		set {Mythical::%{_p}%::Quest::Main::Conditions::*} to {Mythical::NPC::Griv} if uncolored {Mythical::%{_p}%::Form::Type} contains "Earth"
		set {Mythical::%{_p}%::Quest::Main::Name} to "Part III: The Prism Promenade"
		set {Mythical::%{_p}%::Quest::Main::Objective} to "Learn New Ability: Magic"
		set {Mythical::%{_p}%::Quest::Main::Title} to "Professor %{Mythical::NPC::Whick}'s name ? "&aWhick Whiff"%" if uncolored {Mythical::%{_p}%::Form::Type} contains "Air"
		set {Mythical::%{_p}%::Quest::Main::Title} to "Professor %{Mythical::NPC::Esmund}'s name ? "&aEsmund"%" if uncolored {Mythical::%{_p}%::Form::Type} contains "Fire"
		set {Mythical::%{_p}%::Quest::Main::Title} to "Professor %{Mythical::NPC::Ajabadada}'s name ? "&aAjabadada"%" if uncolored {Mythical::%{_p}%::Form::Type} contains "Water"
		set {Mythical::%{_p}%::Quest::Main::Title} to "Professor %{Mythical::NPC::Griv}'s name ? "&aGriv"%" if uncolored {Mythical::%{_p}%::Form::Type} contains "Earth"
		set {Mythical::%{_p}%::Quest::Main::Type} to "Talk to"
		set {Mythical::%{_p}%::Quest::Main::Progress} to 0
		set {Mythical::%{_p}%::Quest::Main::Total} to 1

	# PART IV: Big A's New A-bode
	else if {Mythical::%{_p}%::Quest::Progress} is 5:
		#CUTSCENE 4 - Magic School Professor's Introduction
		cutsceneMaster({_p}, "None", 4, "Story")
		#Each Professor Introduces Themselves
		set {Mythical::%{_p}%::Navigator} to true
		set {Mythical::%{_p}%::Navigator::Location} to location(-580, 64, 1303, world("Mythical_Realms"))
		set {Mythical::%{_p}%::Quest::Main::Condition} to false
		clear {Mythical::%{_p}%::Quest::Main::Conditions::*}
		set {Mythical::%{_p}%::Quest::Main::Name} to "Part IV: Big A's New A-bode"
		set {Mythical::%{_p}%::Quest::Main::Objective} to "Check Out Big A's New A-bode"
		set {Mythical::%{_p}%::Quest::Main::Title} to "&aBig A's New A-bode"
		set {Mythical::%{_p}%::Quest::Main::Type} to "Visit"
		set {Mythical::%{_p}%::Quest::Main::Progress} to 0
		set {Mythical::%{_p}%::Quest::Main::Total} to 1
	else if {Mythical::%{_p}%::Quest::Progress} is 6:
		#CUTSCENE 5 - What's That Amazing, Delectable, Scrumptious Smell?
		cutsceneMaster({_p}, "None", 5, "Story")
		set {Mythical::%{_p}%::Navigator} to true
		set {Mythical::%{_p}%::Navigator::Location} to {Mythical::NPC::Bumbleloaf}'s location
		set {Mythical::%{_p}%::Quest::Main::Condition} to false
		set {Mythical::%{_p}%::Quest::Main::Conditions::*} to {Mythical::NPC::Bumbleloaf}
		set {Mythical::%{_p}%::Quest::Main::Name} to "Part IV: Big A's New A-bode"
		set {Mythical::%{_p}%::Quest::Main::Objective} to "Get a Bumbleloaf Bite!"
		set {Mythical::%{_p}%::Quest::Main::Title} to {Mythical::NPC::Bumbleloaf}'s name ? "&aSir Bumbleloaf"
		set {Mythical::%{_p}%::Quest::Main::Type} to "Talk to"
		set {Mythical::%{_p}%::Quest::Main::Progress} to 0
		set {Mythical::%{_p}%::Quest::Main::Total} to 1
		cutscenePlayer({_p}, 5)#Bumbleloaf's Bites Shot
	else if {Mythical::%{_p}%::Quest::Progress} is 7:
		set {Mythical::%{_p}%::Navigator} to true
		set {Mythical::%{_p}%::Navigator::Location} to location(-803, 84, 1393, world("Mythical_Realms"))
		set {Mythical::%{_p}%::Quest::Main::Condition} to false
		clear {Mythical::%{_p}%::Quest::Main::Conditions::*}
		set {Mythical::%{_p}%::Quest::Main::Name} to "Part IV: Big A's New A-bode"
		set {Mythical::%{_p}%::Quest::Main::Objective} to "Get Back to Business"
		set {Mythical::%{_p}%::Quest::Main::Title} to "&aBig A's New A-bode"
		set {Mythical::%{_p}%::Quest::Main::Type} to "Visit"
		set {Mythical::%{_p}%::Quest::Main::Progress} to 0
		set {Mythical::%{_p}%::Quest::Main::Total} to 1
		#CUTSCENE 6 - Invasion Warning 1
		cutsceneMaster({_p}, "None", 6, "Story")
		#Oakshade Hall Guard Warns About Mob Invasions
	else if {Mythical::%{_p}%::Quest::Progress} is 8:
		set {Mythical::%{_p}%::Navigator} to true
		set {Mythical::%{_p}%::Navigator::Location} to {Mythical::NPC::BigA}'s location
		set {Mythical::%{_p}%::Quest::Main::Condition} to false
		set {Mythical::%{_p}%::Quest::Main::Conditions::*} to {Mythical::NPC::BigA}
		set {Mythical::%{_p}%::Quest::Main::Name} to "Part IV: Big A's New A-bode"
		set {Mythical::%{_p}%::Quest::Main::Objective} to "Chat With Big A"
		set {Mythical::%{_p}%::Quest::Main::Title} to "&aBig Azrael"
		set {Mythical::%{_p}%::Quest::Main::Type} to "Talk to"
		set {Mythical::%{_p}%::Quest::Main::Progress} to 0
		set {Mythical::%{_p}%::Quest::Main::Total} to 1
	
	# PART V: A Grand Quest
	else if {Mythical::%{_p}%::Quest::Progress} is 9:
		#CUTSCENE 7 - Invasion Warning 2 & Bonewart's Second Warning
		cutsceneMaster({_p}, "None", 7, "Story")
		#Bonewart and Cackle Poof in and Give a Threatening Warning to Player & Big A-bode
		#Bonewart and Cackle Poof
		#Big A Informs the Player About the Mythical Information Station
		set {Mythical::%{_p}%::Navigator} to true
		set {Mythical::%{_p}%::Navigator::Location} to location(-530, 64, 1364, world("Mythical_Realms"))
		set {Mythical::%{_p}%::Quest::Main::Condition} to false
		clear {Mythical::%{_p}%::Quest::Main::Conditions::*}
		set {Mythical::%{_p}%::Quest::Main::Name} to "Part V: A Grand Quest"
		set {Mythical::%{_p}%::Quest::Main::Objective} to "Learn About the Mythical Realms"
		set {Mythical::%{_p}%::Quest::Main::Title} to "&aMythical Information Station"
		set {Mythical::%{_p}%::Quest::Main::Type} to "Visit"
		set {Mythical::%{_p}%::Quest::Main::Progress} to 0
		set {Mythical::%{_p}%::Quest::Main::Total} to 1
	else if {Mythical::%{_p}%::Quest::Progress} is 10:
		set {Mythical::%{_p}%::Navigator} to true
		set {Mythical::%{_p}%::Navigator::Location} to location(-530, 64, 1364, world("Mythical_Realms"))
		set {Mythical::%{_p}%::Quest::Main::Condition} to false
		set {Mythical::%{_p}%::Quest::Main::Conditions::*} to {Mythical::NPC::Brella} and {Mythical::NPC::Oops} and {Mythical::NPC::Dandelion} and {Mythical::NPC::Cedric}
		set {Mythical::%{_p}%::Quest::Main::Name} to "Part V: A Grand Quest"
		set {Mythical::%{_p}%::Quest::Main::Objective} to "Learn About the Mythical Realms"
		set {Mythical::%{_p}%::Quest::Main::Title} to "&aAny Receptionist"
		set {Mythical::%{_p}%::Quest::Main::Type} to "Talk to"
		set {Mythical::%{_p}%::Quest::Main::Progress} to 0
		set {Mythical::%{_p}%::Quest::Main::Total} to 1
	else if {Mythical::%{_p}%::Quest::Progress} is 11:
		set {Mythical::%{_p}%::Navigator} to true
		set {Mythical::%{_p}%::Navigator::Location} to location(-475, 79, 1300, world("Mythical_Realms"))
		set {Mythical::%{_p}%::Quest::Main::Condition} to false
		clear {Mythical::%{_p}%::Quest::Main::Conditions::*}
		set {Mythical::%{_p}%::Quest::Main::Name} to "Part V: A Grand Quest"
		set {Mythical::%{_p}%::Quest::Main::Objective} to "Visit Central Castle in Oak Commons"
		set {Mythical::%{_p}%::Quest::Main::Title} to "&aGrand Room"
		set {Mythical::%{_p}%::Quest::Main::Type} to "Visit"
		set {Mythical::%{_p}%::Quest::Main::Progress} to 0
		set {Mythical::%{_p}%::Quest::Main::Total} to 1
		cutscenePlayer({_p}, 7) #Central Castle Shot
	else if {Mythical::%{_p}%::Quest::Progress} is 12:
		set {Mythical::%{_p}%::Navigator} to true
		set {Mythical::%{_p}%::Navigator::Location} to {Mythical::NPC::Morrin}'s location
		set {Mythical::%{_p}%::Quest::Main::Condition} to false
		set {Mythical::%{_p}%::Quest::Main::Conditions::*} to {Mythical::NPC::Morrin}
		set {Mythical::%{_p}%::Quest::Main::Name} to "Part V: A Grand Quest"
		set {Mythical::%{_p}%::Quest::Main::Objective} to "Find the Stock Shop"
		set {Mythical::%{_p}%::Quest::Main::Title} to "&aMorrin Wetheath"
		set {Mythical::%{_p}%::Quest::Main::Type} to "Talk to"
		set {Mythical::%{_p}%::Quest::Main::Progress} to 0
		set {Mythical::%{_p}%::Quest::Main::Total} to 1
		#Morrin Says the Stock Shop is Not Operational Anymore
		#Morrin Also Says Merchants Around Town Have Items to Get
		#Morrin Then Informs You of the Circus Across the Way, and to Start There
	else if {Mythical::%{_p}%::Quest::Progress} is 13:
		set {Mythical::%{_p}%::Navigator} to true
		set {Mythical::%{_p}%::Navigator::Location} to location(-421, 64, 1376, world("Mythical_Realms"))
		set {Mythical::%{_p}%::Quest::Main::Condition} to false
		clear {Mythical::%{_p}%::Quest::Main::Conditionals::*}
		clear {Mythical::%{_p}%::Quest::Main::Conditions::*}
		set {Mythical::%{_p}%::Quest::Main::Name} to "Part V: A Grand Quest"
		set {Mythical::%{_p}%::Quest::Main::Objective} to "Visit Circus in Oak Commons"
		set {Mythical::%{_p}%::Quest::Main::Title} to "&aCircus Big Top"
		set {Mythical::%{_p}%::Quest::Main::Type} to "Visit"
		set {Mythical::%{_p}%::Quest::Main::Progress} to 0
		set {Mythical::%{_p}%::Quest::Main::Total} to 1
		cutscenePlayer({_p}, 8) #Circus Big Top Shot
	else if {Mythical::%{_p}%::Quest::Progress} is 14:
		set {Mythical::%{_p}%::Navigator} to true
