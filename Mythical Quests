#set {Mythical::Dungeon::1::LocWait} to location(-433.5, 64, 882.5, world("Mythical_Realms"))
#set {Mythical::Dungeon::1::LocStart} to location(-433.5, 64, 882.5, world("Mythical_Realms"))
#set {Mythical::Dungeon::1::LocMobs::*} to location(-433.5, 64, 882.5, world("Mythical_Realms"))
#set {Mythical::Dungeon::1::LocEnd} to location(-433.5, 64, 882.5, world("Mythical_Realms"))
#set {Mythical::Dungeon::1::Required} to 1
#set {Mythical::Dungeon::1::Timer} to 120
#{Mythical::Dungeon::1::Players::*}
#{Mythical::Dungeon::1::Rewards::*}

#set {Mythical::Dungeon::1::Status} to "Recruiting"
#STATUS:
#Recruiting:Waiting for Players
#Boarding:Waiting to Enter
#Crawling:Dungeon Active
#Rewarding:Ending
#Completed:Restoring or Waiting to Reset

#set {Mythical::Dungeon::1::Type} to "Boss"
#TYPES
#Run:Run to the end to complete the dungeon!
#Regular:Defeat x mobs or complete puzzle to progress to next room and/or complete the dungeon.
#Timer:Complete the dungeon before the timer ends.
#Hoard:Defeat x mobs in x waves to complete the dungeon.
#Boss:Defeat the boss to complete the dungeon.
#set {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Type::Run} to "Run to the End!"
#set {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Type::Regular} to "Complete Each Room!"
#set {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Type::Timer} to "Find the End Before Time's Up!"
#set {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Type::Hoard} to "Defeat All Enemies!"
#set {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Type::Boss} to "Find & Kill %{Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Boss} ? "The Boss"%!"

#set {Mythical::Dungeon::1::Difficulty} to 1
#DIFFICULTIES
#1:Easiest(1.0-1.9)
#2:Easy(2.0-2.9)
#3:Regular(3.0-3.9)
#4:Moderate(4.0-4.9)
#5:Difficult(5.0-5.9)
#6:Challenge(6.0-6.9)


	#set {Mythical::%{_p}%::Dungeon::Active} to nearest {Mythical::Dungeon::%loop-value%::LocWait} relative to {_p}
	{Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Players::*} does not contain {_p}:
		add {_p} to {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Players::*} if {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Players::*} does not contain {_p}
		{Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Timer} is not set:
			set {Mythical::Dungeon::Type::Run} to "Run to the End"
			set {Mythical::Dungeon::Type::Regular} to "Complete Each Room"
			set {Mythical::Dungeon::Type::Timer} to "Find the End Before Time's Up"
			set {Mythical::Dungeon::Type::Hoard} to "Defeat All Enemies"
			set {Mythical::Dungeon::Type::Boss} to "Find & Kill %{Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Boss} ? "The Boss"%"
			{Mythical::%{_p}%::Dungeon::Active} is 1:
				set {Mythical::Dungeon::1::Title} to "Oakshade Community Dungeon"
				set {Mythical::Dungeon::1::Required} to 1
				set {Mythical::Dungeon::1::Difficulty} to 1
				set {Mythical::Dungeon::1::Type} to "Boss"
				set {Mythical::Dungeon::1::Boss} to "King Rotter"
				clear {Mythical::Dungeon::1::Rewards::*}
			else if {Mythical::%{_p}%::Dungeon::Active} is 2:
				set {Mythical::Dungeon::2::Title} to "Oakshade Caverns"
				set {Mythical::Dungeon::2::Required} to 1
				set {Mythical::Dungeon::2::Difficulty} to 1
				set {Mythical::Dungeon::2::Type} to "Hoard"
				clear {Mythical::Dungeon::2::Boss}
				clear {Mythical::Dungeon::2::Rewards::*}
			{Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::LocWait} is set
			{Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::LocStart} is set
			set {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Status} to "Recruiting"
			broadcast " {@info} %{Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Title}% is Now Recruiting for Players!"
			broadcast " {@info} Go Near the Dungeon to Enter"
			set {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Timer} to 120
			send "" to {_p}
			send " {@info} You've Been Recruited to %{Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Title} ? "a Dungeon"%" to {_p}
			send " {@info} Waiting for More Players to Enter..." to {_p}
		else if {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Status} is "Recruiting":
			send "" to {_p}
			send " {@info} You've Been Recruited to %{Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Title} ? "a Dungeon"%" to {_p}
			send " {@info} Waiting for More Players to Enter..." to {_p}
			loop {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Players::*}:
				send " {@info} %{_p}'s display name ? {_p}%<#CB625F> Joined the Recruitment For %{Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Title} ? "the Dungeon"%" to loop-value
				{Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Difficulty} is less than 7:
					add 0.5 to {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Difficulty} if {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Difficulty} is less than 7
					send " {@info} Difficulty Increase! Difficulty: &7%{Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Difficulty}%" to {_p}
			set {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Timer} to 10 if amount of {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Players::*} is more than ({Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Difficulty} * 2)
	{Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Status} is "Recruiting":
		remove (1 / amount of {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Players::*}) from {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Timer}
		{Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Timer} is less than 0
		{Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::LocStart} is set
		set {Mythical::Dungeon::1::Status} to "Boarding"
		clear {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Timer}
		amount of {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Players::*} is more than ({Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Required} - 1):
			set {Mythical::Dungeon::1::Status} to "Crawling"
			broadcast " {@info} %{Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Title}% is Starting..."
		loop {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Players::*}:
			teleport loop-value to {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::LocStart}
			send " {@info} %{Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Title} ? "The Dungeon"% Has Begun!" to {_p}
			send title "Go! Go! Go!" with subtitle {Mythical::Dungeon::Type::%{Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Type}%} ? "Find the Exit!" to {_p} for 10 seconds
	else if {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Status} is "Crawling":
		chance of 0.001%:
			kill all zombies and skeletons and spiders and creepers and silverfish in radius 100 of {_p}
		add (1 / amount of {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Players::*}) to {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Timer}
		
		#WOOLS
		#LIME-Zombie
		#GREEN-Creeper
		#RED-Spider
		#WHITE-Skeleton
		#LIGHT GRAY-Silverfish
		loop all blocks in radius 8 of {_p}:
			stop loop if amount of entities in radius 8 of {_p} is more than ({Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Difficulty} * 7)
			loop-block is lime wool:
				chance of ({Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Difficulty} * 0.5)
				spawn zombie 1.5 meters above loop-block
				#Zombie Rotter
				set the generic scale attribute of last spawned zombie to random number between 0.5 and 1
				set the generic knockback resistance attribute of last spawned zombie to 10
				set the generic attack damage attribute of last spawned zombie to 1
				set the generic movement speed attribute of last spawned zombie to 0.15
				set last spawned zombie's max health to random integer between 1 and 3
				set last spawned zombie's health to 3
				set {Mythical::%last spawned zombie%::Name} to "&0Rotter"
				set last spawned zombie's tool to cornflower or wooden sword of sharpness 2 or iron sword
				equip last spawned zombie with leather chestplate and leather leggings and leather boots
				chance of 15%:
					equip last spawned zombie with iron chestplate and iron leggings and iron boots
				chance of 5%:
					equip last spawned zombie with netherite chestplate and netherite leggings and netherite boots
				apply jump boost without particles to last spawned zombie for 9999 days
			loop-block is green wool:
				chance of ({Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Difficulty} * 0.1)
				spawn creeper 1.5 meters above loop-block
			loop-block is red wool:
				chance of ({Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Difficulty} * 0.3)
				spawn spider 1.5 meters above loop-block
				#Web Widow
				set the generic scale attribute of last spawned spider to random number between 0.8 and 1.2
				set the generic attack damage attribute of last spawned spider to 1.5
				set the generic movement speed attribute of last spawned spider to random number between 0.2 and 0.6
				set last spawned spider's max health to random integer between 3 and 6
				set last spawned spider's health to 6
				set {Mythical::%last spawned spider%::Name} to "&0Web Widow"
			loop-block is white wool:
				chance of ({Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Difficulty} * 0.2)
				spawn skeleton 1.5 meters above loop-block
				#Dusk Archer
				set the generic scale attribute of last spawned skeleton to random number between 0.8 and 1.2
				set the generic attack damage attribute of last spawned skeleton to 1
				set the generic movement speed attribute of last spawned skeleton to 0.3
				set last spawned skeleton's max health to random integer between 2 and 4
				set last spawned skeleton's health to 4
				set {Mythical::%last spawned skeleton%::Name} to "&0Dusk Archer"
				set last spawned skeleton's tool to bow or wooden sword of sharpness 2
				chance of 25%:
					equip last spawned skeleton with leather chestplate and leather leggings and leather boots
				chance of 15%:
					equip last spawned skeleton with iron chestplate and iron leggings and iron boots
				chance of 5%:
					equip last spawned skeleton with netherite chestplate and netherite leggings and netherite boots
			loop-block is light gray wool:
				chance of ({Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Difficulty} * 0.2)
				spawn silverfish 1.5 meters above loop-block
				#Sewer Rat
				set the generic scale attribute of last spawned silverfish to random number between 0.8 and 1.8
				set the generic attack damage attribute of last spawned silverfish to 4
				set the generic movement speed attribute of last spawned silverfish to random number between 0.1 and 0.2
				set last spawned silverfish's max health to random integer between 3 and 6
				set last spawned silverfish's health to 6
				set {Mythical::%last spawned silverfish%::Name} to "&7Sewer Rat"
			
			#CONCRETES
			#LIME-ZOMBIE
			loop-block is lime concrete:
				loop all entities in radius 10 of loop-block:
					stop if loop-entity is zombie
				spawn zombie 1.5 meters above loop-block
				#Zombie King Rotter
				set the generic scale attribute of last spawned zombie to random number between 1.5 and 2
				set the generic knockback resistance attribute of last spawned zombie to 10
				set the generic attack damage attribute of last spawned zombie to 2
				set the generic movement speed attribute of last spawned zombie to 0.25
				set last spawned zombie's max health to 40
				set last spawned zombie's health to 40
				set {Mythical::%last spawned zombie%::Name} to "&6King Rotter"
				set last spawned zombie's name to "&6King Rotter"
				set last spawned zombie's tool to diamond sword of sharpness 5
				equip last spawned zombie with netherite chestplate and netherite leggings and netherite boots
				apply jump boost without particles to last spawned zombie for 9999 days
		{Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Timer} is more than 1800:
			set {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Status} to "Rewarding"
			broadcast " {@info} Times Up For %{Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Title}%..."
	else if {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Status} is "Rewarding":
		kill all zombies and skeletons and spiders and creepers and silverfish in radius 100 of {_p}
		broadcast " {@info} %{Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Title}% Was Conquered by %{Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Players::*}%!"
		set {Mythical::%{_p}%::Temp} to {Mythical::%{_p}%::Dungeon::Active}
		set {Mythical::Dungeon::%{Mythical::%{_p}%::Temp}%::Status} to "Completed"
		wait 10 seconds
		loop {Mythical::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Players::*}:
			set {Mythical::%loop-value%::Quest::Main::Condition} to false if {Mythical::%loop-value%::Quest::Main::Condition} is "Dungeon"
			set {Mythical::%loop-value%::Dungeon::%{Mythical::%{_p}%::Dungeon::Active}%::Complete} to "Completed"
			teleport loop-value to {Mythical::Dungeon::%{Mythical::%{_p}%::Temp}%::LocWait}
			remove loop-value from {Mythical::Dungeon::%{Mythical::%{_p}%::Temp}%::Players::*}
			clear {Mythical::%loop-value%::Dungeon::*}
		clear {Mythical::Dungeon::%{Mythical::%{_p}%::Temp}%::Players::*}
		set {Mythical::Dungeon::%{Mythical::%{_p}%::Temp}%::Status} to "Recruiting"
		clear {Mythical::Dungeon::%{Mythical::%{_p}%::Temp}%::Timer}
		clear {Mythical::%{_p}%::Temp}
